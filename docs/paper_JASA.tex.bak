\section*{Appendix}

\section{Additional implementation details}

% {\color{red} To add: regularized regression version of $\widehat{\beta}_l$. Organize the cross-fitting details.}


\subsection{Cross-fitting details}
\label{sec:app:cross-details}
In this section, we present the details of cross-fitting. We randomly partition $\Dsc_l$ into two disjoint subsets $\mathcal{A}_l$ and $\mathcal{B}_l$ for both outcomes and covariates. We can simply assume that $\mathcal{A}_l$ contains the first $\lfloor n_l / 2\rfloor$ outcome observations and the first $\lfloor N_l / 2\rfloor$ predictors observations, while $\mathcal{B}_l$ contains the remaining ones. We also partition the target covariates data $\Dsc_0$ into $\Asc_0 =\{1,2,\cdots,\lfloor N_0 / 2\rfloor\}$ and $\Bsc_0 = [N_0]\backslash\Asc_0$.

% {\darkblue [Klaassen, 1987, Schick, 1986, Chernozhukov et al., 2018] from DRML}

When fitting imputation model $\mlha$, we use labeled source data in $\Asc_l$. When we employ the sample splitting method to train the auxiliary density ratio model $\rlha$, we also split the reference samples into $\{X_j^{(\operatorname{ref})}\}_{j\in \Asc_{\operatorname{ref}}}$ and $\{X_j^{(\operatorname{ref})}\}_{j\in \Bsc_{\operatorname{ref}}}$. In specific, we merge $\{X_i^{(l)}\}_{i \in \Asc_l}$ with the reference covariates $\{X_j^{(\operatorname{ref})}\}_{j \in \Asc_{\operatorname{ref}}}$ and denote the merged covariates as $\{\tilde{X}_i^{(l)}\}_{i \in\left[|\Asc_l|+|\Asc_{\operatorname{ref}}|\right]}$, then do the same operations as before in (\ref{eq:densityratio}) to get $\rlha$. When learning the weight $\rha$, we use $\rlha$ in (\ref{eq:kldiv-est}) and perform minimization on the target sample $\Asc_0$. We can then obtain the plug-in sample splitting version of posterior probability model $\elha$ and density ratio against target distribution $\wlha$. Following the same procedure we can get $\mlhb,\rlhb,\widehat{\rho}^\Bsc,\elhb$ and $\wlhb$.

For the estimation of $\bar{\beta}_l$, we denote the sample splitting empirical operator $\cplha = |\Asc_l|\inv \sum_{i \in \Asc_l}$ and $\cplhb = |\Bsc_l|\inv \sum_{i \in \Bsc_l}$. Then the empirical estimation for $\bar{\beta}_l,\ l \in [L]$ will be
\begin{align}
    \qlha & =  \cpzh  \left(\mlha(X\uz_i) (\szh)^{-1} A\uz_i \right) + \cplhb \left( \wlha(X^{(l)}_i)[Y^{(l)}_i-\mlha(X^{(l)}_i)] (\szh)^{-1} A\ul_i \right), \label{eq:Qlhata} \\
    \qlhb & =  \cpzh  \left(\mlhb(X\uz_i) (\szh)^{-1} A\uz_i \right) + \cplha \left( \wlhb(X^{(l)}_i)[Y^{(l)}_i-\mlhb(X^{(l)}_i)] (\szh)^{-1} A\ul_i \right). \label{eq:Qlhatb}
\end{align}
Here the target empirical operator $\cpzh = N_0\inv \sum_{i=1}^{N_0}$ is on the whole target dataset, as $\mlha,\mlhb$ are independent of target samples. For the sample splitting version of $\widehat{\beta}_{\mix}$, we need to split the target data to create independence of data and nuisance model $\elh$. We denote the sample splitting empirical operator on the target as $\cpzha = |\Asc_0|\inv\sum_{i\in \Asc_0}$ and  $\cpzhb = |\Bsc_0|\inv\sum_{i\in \Bsc_0}$. Then the empirical estimation of $\bar{\beta}_{\mix}$ will be 
\begin{align}
    \widehat{\beta}^\Asc_{\mix} = \pha &= \suml \left( \cpzhb \elha(X\uz_i)\mlha(X\uz_i)(\szh)\inv A\uz_i \right. \nonumber \\
    &\qquad \left. +\ \cplhb \elha(X\ul_j) \wlha(X\ul_j) [Y\ul_j - \mlha(X\ul_j)](\szh)\inv A\ul_j \right), \label{eq:ql+1hata} \\
    \widehat{\beta}^\Bsc_{\mix} = \phb &= \suml \left( \cpzha \elhb(X\uz_i)\mlhb(X\uz_i)(\szh)\inv A\uz_i \right. \nonumber \\
    &\qquad \left. +\ \cplha \elhb(X\ul_j) \wlhb(X\ul_j) [Y\ul_j - \mlhb(X\ul_j)](\szh)\inv A\ul_j \right). \label{eq:ql+1hatb}
\end{align}


In the following Algorithm \ref{algo:DORM}, we summarize our proposal for the general covariate-shift setting. %We consider that the $L$ source data sets are respectively stored in the $L$ source sites while the data for the target population is stored in the target site.
In the algorithm we assume that the decoupling budget $\smax$ is pre-specified. In practice, we can determine it by some side information or tuning with small numbers of $Y\uz_i$ on the target or surrogate variables as discussed in Section \ref{sec:tuning}.
\begin{algorithm}[H]
\caption{Overview of DORM Algorithm}
\label{algo:DORM}
\begin{algorithmic}[0]
\REQUIRE  Source data $\Dsc_l = \{\{(A_i\ul,W_i\ul)\}_{i\in [N_l]}, \{Y_i\ul\}_{i\in [n_l]}\}, l \in [L]$, target covariates $\Dsc_0 = \{(A_i\uz,W_i\uz)\}_{i\in[N_0]}$, the decoupling budget $\smax$. (Assuming that we have partitioned the datasets into $\Asc$ and $\Bsc$.)
\ENSURE DORM estimator $\ours(\smax)$

%\STATE $\backslash$* On source sites *$\backslash$
\FOR{$l=1$ to $L$}
    \STATE Fit the imputation model estimator $\mlha$,$\mlhb$
    \STATE Fit the auxiliary density ratio estimator $\rlha$,$\rlhb$ as in (\ref{eq:densityratio})
\ENDFOR

%\STATE $\backslash$* On target site *$\backslash$
    \STATE Calculate the prior probability $\rha,\rhb$ as in (\ref{eq:kldiv-est})

%\STATE $\backslash$* On source sites *$\backslash$
\FOR{$l=1$ to $L$}
    \STATE Construct the posterior probability estimator $\elha$,$\elhb$ as in (\ref{eq:etalhat})
    \STATE Construct the density ratio estimator $\wlha$,$\wlhb$
\ENDFOR

%\FOR{$l=1$ to $L+1$}
%    \STATE Compute the bias-correction term $C_l^\Asc$,$C^\Bsc_l$
%\ENDFOR

%\STATE $\backslash$* Transmit $\{\Csc_l^\Asc,\Csc^\Bsc_l\}_{l\in[L+1]}$ to target site *$\backslash$
\FOR{$l=1$ to $L+1$}
    \STATE Compute the sample splitting estimator $\qlha$,$\qlhb$ as in (\ref{eq:Qlhata})-(\ref{eq:ql+1hatb}).
\ENDFOR
\STATE Compute the estimator $\widehat{\Gamma}^\Asc,\widehat{\Gamma}^\Bsc$ as in Theorem \ref{thm:PopuIdenti}
\STATE Compute the data-dependent optimal weight $\widehat{\gamma}$ as $\widehat{\gamma}^{\Asc,\Bsc} = \arg\min_{\gamma \in \mathcal{S}(\smax)} \gamma\trans \widehat{\Gamma}^{\Asc,\Bsc} \gamma$
\STATE Return $\ours(\smax) = \sum_{l=1}^{L+1} (\glha \qlha + \glhb \qlhb)/2$
\end{algorithmic}
\end{algorithm}

\subsection{Regularized version of DORM}
\label{sec:app:regularize}
In the paper, we primarily focus on the setting where the covariates of interest, $A$, are low-dimensional and the sample covariance matrix $\szh$ is invertible. When $A$ is high-dimensional (e.g., $\max_{l} n_l < q < p$), we can no longer directly invert $\szh$ to construct (\ref{eq:qlhat}) and (\ref{eq:ql+1hat}). To address this, in such high-dimensional scenarios, we propose a regularized version of DORM, which ensures the method remains applicable even when the number of covariates exceeds the sample size. We drop the sample splitting notation here for simplicity.

For $\qlh$, we define the empirical doubly robust loss function as 
\begin{equation}
    {\rm DR}\ul(\beta) := \cpzh \left(\mlh(X\uz_i) + \cplh \wlh (X\ul_j)[Y\ul_j-\mlh(X\ul_j)] - \beta\trans A\uz_i \right)^2.
\label{eq:DROoss1}
\end{equation}
When $\szh = \cpzh A\uz_i(A\uz_i)\trans$ is invertible, the minimizer of (\ref{eq:DROoss1}) is equivalent to $\qlh$ in (\ref{eq:qlhat}). In the high-dimensional setting, we define the $\qlh$ as the minimizer of the following elastic-net regularized minimization problem:
\begin{equation*}
    \qlh := \underset{\beta}{\arg\min}~ {\rm DR}\ul(\beta) + \lambda \left[\alpha \|\beta\|_1 + (1-\alpha)\|\beta\|_2^2/2 \right].
\label{eq:qlh-elastic}
\end{equation*}
Similarly, for $\ph$, we define the empirical doubly robust loss function as
\begin{equation*}
    {\rm DR}^{(L+1)}(\beta) := \cpzh \left( \suml\elh(X\uz_i)\mlh(\X\uz_i) + \suml \cplh \elh(X\ul_j) \wlh(X\ul_j) [Y\ul_j - \mlh(X\ul_j)] - \beta\trans A\ul_j  \right)^2. 
\end{equation*}
So when $\szh = \cpzh A\uz_i(A\uz_i)\trans$ is invertible, the minimizer of (\ref{eq:DROoss1}) is $\ph$ in (\ref{eq:ql+1hat}). When $\szh = \cpzh A\uz_i(A\uz_i)\trans$ is not invertible, we define the $\ph$ as the minimizer of the following elastic-net regularized minimization problem:
\begin{equation*}
    \ph := \underset{\beta}{\arg\min}\quad {\rm DR}^{(L+1)}(\beta) + \lambda \left[\alpha \|\beta\|_1 + (1-\alpha)\|\beta\|_2^2/2 \right].
\label{eq:ql+1h-elastic}
\end{equation*}
In practice, one could use cross-validation to choose the best tuning parameters $\alpha$ and $\lambda$.

\section{Additional details for Section \ref{sec:complicated}}


\subsection{Recovery of intrinsic sources}
\label{sec:appen:latent}

In this subsection, we describe an approach for the recovery of intrinsic sources based on the mutual contamination (demixing) framework in \citet{katz2019decontamination}. Throughout this subsection, $\PP^{(l)}$ denotes the (unlabeled) covariate law on $\RR^p$ for observed source $l\in[L]$; the intrinsic sources are denoted by $\{\QQ_j\}_{j=1}^m$ with $m\le L$.

For two distributions $F,H$ on $\RR^p$, define \citep{katz2019decontamination}
\begin{equation*}
\kappa^\star(F\|H)\;:=\;\sup\Big\{\kappa\in[0,1]: \exists\,G \ \text{s.t. } F=\kappa H + (1-\kappa)G\Big\}
\;=\;\inf_{A:\,H(A)>0} \frac{F(A)}{H(A)}.
\label{eq:tau-star-def}
\end{equation*}
Intuitively, $\kappa^\star(F\|H)$ is the largest fraction of $F$ that can be explained by $H$; the remainder is the \emph{residual} component. Whenever $\kappa^\star(F\|H)<1$, the corresponding \emph{residue} is
\begin{equation*}
\Res(F\!\mid\!H)\ :=\ \frac{F-\kappa^\star(F\|H)\,H}{1-\kappa^\star(F\|H)}.
\label{eq:residue-def}
\end{equation*}
If $F,H$ admit densities $f,h$ with $F\ll H$, then $\kappa^\star(F\|H)=\mathrm{essinf}_x f(x)/h(x)$ and $\Res(F\mid H)$ has density $(f-\kappa^\star h)/(1-\kappa^\star)$.

Assume each observed source is a mixture of $m\le L$ intrinsic sources:
\begin{equation}
\PP^{(l)} \;=\; \sum_{j=1}^m \pi_{lj}\, \QQ_j,\qquad \pi_{l\cdot}\in\Delta_m,
\quad \Pi^*:=(\pi_{lj})_{l,j}\ \text{has full column rank,}
\label{eq:mutual-contam-model}
\end{equation}
and the $\QQ_j$ are \emph{irreducible} in the sense of \citet{katz2019decontamination} (no $\QQ_j$ is a nontrivial mixture of the others). Under \eqref{eq:mutual-contam-model} and irreducibility, $\{\QQ_j\}_{j=1}^m$ is identifiable up to permutation. Moreover, since $\Pi^*$ has full column rank, each intrinsic source lies in the \emph{affine span} of the observed sources:
\begin{equation}
\QQ_j \;=\; \sum_{l=1}^L \alpha_{lj}\,\PP^{(l)},\qquad \sum_{l=1}^L \alpha_{lj}=1,
\label{eq:affine-rep}
\end{equation}
where the coefficients $\alpha_{lj}$ need not be nonnegative in general. A constructive route to recover $\{\QQ_j\}$ uses iterative residue operations. Below we present a practical residue-demixing scheme adapted to our setting.

\medskip\noindent
\emph{Algorithm (residue demixing).}
Let $\mathcal{S}_0=\{\PP^{(1)},\dots,\PP^{(L)}\}$.
\begin{enumerate}
\item \textbf{Initialization.}
Select $m$ seed distributions $\mathcal{C}_0=\{C^{(0)}_1,\dots,C^{(0)}_m\}\subseteq\mathcal{S}_0$ with large pairwise discrepancy (e.g., maximizing a minimum pairwise divergence/distance); if $L=m$, take $\mathcal{C}_0=\mathcal{S}_0$.
\item \textbf{Residue sweeps.}
For $t=0,1,\dots$, sweep over all unordered pairs $\{i,j\}\subset[m]$ and update the more-contaminated element by removing the other:
\[
\text{if }\ \kappa^\star\!\big(C^{(t)}_i \,\big\|\, C^{(t)}_j\big)\ \ge\ \kappa^\star\!\big(C^{(t)}_j \,\big\|\, C^{(t)}_i\big),\ \ 
C^{(t+1)}_i \leftarrow \Res\!\big(C^{(t)}_i\mid C^{(t)}_j\big),\ \ C^{(t+1)}_j \leftarrow C^{(t)}_j,
\]
and otherwise symmetrically update $j$.
\item \textbf{Stopping.}
Terminate when $\max_{i\neq j}\kappa^\star(C^{(T)}_i\|C^{(T)}_j)$ is sufficiently close to $0$ (numerically), or after a pre-specified number of sweeps. Output ${\QQ}_j:=C^{(T)}_j$, $j\in[m]$.
% \item \textbf{Mixing weight recovery.}
% Given $\{{\QQ}_j\}_{j=1}^m$, estimate each $\pi_{l\cdot}$ by fitting $\PP^{(l)}$ to the recovered components:
% \begin{equation}
% {\pi}_{l\cdot}\in \arg\min_{\pi\in\Delta_m}\ 
% D_{\mathrm{KL}}\!\Big(\PP^{(l)}\ \Big\|\ \sum_{j=1}^m \pi_j\, {\QQ}_j\Big).
% \label{eq:pi-fit}
% \end{equation}
\end{enumerate}

We now describe how to implement the above steps with finite samples, leveraging the same density-ratio machinery used in Section~\ref{sec:method:est} of the main paper. Fix a reference distribution $\PP^{(\mathrm{ref})}$ on $\RR^p$ as in \eqref{eq:barrl} of the main paper, and let
\[
\bar r_l(x)\ :=\ \frac{\mathrm{d} \PP^{(l)}(x)}{\mathrm{d} \PP^{(\mathrm{ref})}(x)},\qquad l\in[L],
\]
with estimators $\widehat r_l$ obtained via probabilistic classification in \eqref{eq:barrl}.
For any affine combination $F=\sum_{l=1}^L a_l\,\PP^{(l)}$ with $\sum_l a_l=1$, define the induced ratio
\begin{equation}
\bar r_F(x)\ :=\ \frac{\mathrm{d}F(x)}{\mathrm{d} \PP^{(\mathrm{ref})}(x)}\ =\ \sum_{l=1}^L a_l\,\bar r_l(x),
\qquad 
\widehat r_F(x)\ :=\ \sum_{l=1}^L a_l\,\widehat r_l(x).
\label{eq:r-affine}
\end{equation}
This representation is convenient because residue updates are affine: if $F=\sum_l a_l\PP^{(l)}$ and $H=\sum_l b_l\PP^{(l)}$, then
\begin{equation}
\Res(F\mid H)\ =\ \sum_{l=1}^L \frac{a_l-\kappa^\star(F\|H)\,b_l}{1-\kappa^\star(F\|H)}\,\PP^{(l)},
\label{eq:residue-affine}
\end{equation}
so we can maintain each candidate $C_i^{(t)}$ via its coefficient vector over $\{\PP^{(l)}\}_{l=1}^L$.


When $F,H\ll \PP^{(\mathrm{ref})}$, we have
\[
\kappa^\star(F\|H)\ =\ \mathrm{essinf}_x \frac{\mathrm{d}F(x)}{\mathrm{d}H(x)}
\ =\ \mathrm{essinf}_x \frac{\bar r_F(x)}{\bar r_H(x)}.
\]
A practical plug-in estimator is obtained by replacing $(\bar r_F,\bar r_H)$ with $(\widehat r_F,\widehat r_H)$ and approximating the essential infimum by a lower empirical quantile under $H$:
\begin{equation*}
\widehat\kappa(F\|H)\ :=\ Q_{\tau}\Big(\Big\{\frac{\widehat r_F(X_i)}{\widehat r_H(X_i)}:\ X_i\sim \widehat H\Big\}\Big),
\qquad \tau\in(0,0.05]\ \text{small},
\end{equation*}
where $Q_{\tau}$ denotes empirical $\tau$-quantile and $\{X_i\sim \widehat H\}$ are samples drawn from (or reweighted to approximate) $H$. The quantile (rather than the raw minimum) stabilizes estimation in finite samples; in implementations we also truncate can $\widehat r_F/\widehat r_H$ away from $0$ and $\infty$.


Given $\widehat\kappa(F\|H)$, we update the coefficient vector of $F$ via \eqref{eq:residue-affine} with $\kappa^\star$ replaced by $\widehat\kappa$. Equivalently, at the level of density ratios to $\PP^{(\mathrm{ref})}$, the residue ratio satisfies
\begin{equation}
\widehat r_{\Res(F\mid H)}(x)\ =\ 
\frac{\big[\widehat r_F(x)-\widehat\kappa(F\|H)\,\widehat r_H(x)\big]_+}{1-\widehat\kappa(F\|H)},
\label{eq:r-residue}
\end{equation}
where $[\cdot]_+$ truncates negative values caused by estimation error (and is typically inactive under adequate sample size and overlap). This yields a fully plug-in implementation of the residue sweeps in terms of $(\widehat r_l)_{l\in[L]}$.

% Problem \eqref{eq:pi-fit} is equivalent (up to an additive constant independent of $\pi$) to maximizing the log-likelihood of the mixture under $\PP^{(l)}$:
% \[
% \widehat{\pi}_{l\cdot}\in\arg\max_{\pi\in\Delta_m}\ \E_{\PP^{(l)}}\log\Big(\sum_{j=1}^m \pi_j\, q_j(X)\Big),
% \qquad q_j:=\frac{\mathrm{d}\QQ_j}{\mathrm{d} \PP^{(\mathrm{ref})}}.
% \]
% With $\widehat r_{\widehat\QQ_j}$ available from \eqref{eq:r-affine}--\eqref{eq:r-residue}, the empirical version becomes
% \begin{equation*}
% \widehat{\pi}_{l\cdot}\in\arg\max_{\pi\in\Delta_m}\ 
% \frac{1}{N_l}\sum_{i=1}^{N_l}\log\Big(\sum_{j=1}^m \pi_j\,\widehat r_{\widehat\QQ_j}(X^{(l)}_i)\Big),
% \label{eq:pi-fit-emp}
% \end{equation*}
% which is a smooth convex optimization over the simplex and can be solved by projected gradient methods or exponentiated-gradient updates.

After obtaining $\{\widehat\QQ_j\}_{j=1}^m$, we can treat them as the ``sources'' in the DORM constructions by replacing $\{\widehat{\PP}^{(l)}\}_{l=1}^L$ with $\{\widehat\QQ_j\}_{j=1}^m$ in the mixture approximation step for the target covariate law and the induced posterior weights as \eqref{eq:kldiv-est} and \eqref{eq:etalhat} in the main paper, using $\widehat r_{\widehat\QQ_j}$ in place of $\widehat r_l$ for estimation. Operationally, working with intrinsic sources restricts the mixture approximation to a lower-dimensional simplex and can yield sharper posterior weights. Moreover, via \eqref{eq:affine-rep} it is equivalent to allowing affine (potentially signed) combinations of observed sources when representing latent mixture components.

\subsection{Details for our method under pre-mixing covariates}
\label{sec:appen:adjust detail}

Let $X=(X_{\mathcal D},X_{\mathcal D^c})$, where $X_{\mathcal D}$ are {pre-mixing} covariates whose marginal law may shift freely across domains, while the mixture structure relevant for transfer is assumed to operate on $(X_{\mathcal D^c},Y)\mid X_{\mathcal D}$. Recall the adjusted fully $(X,Y)$-coupled (joint-mixing-after-adjustment) regime in \eqref{eq:cond-joint}; under \eqref{eq:cond-joint}, the target conditional law admits the posterior-weighted representation
\begin{equation*}
\PP^{(0)}_{Y | X}(dy\mid x_{\mathcal D},x_{\mathcal D^c})
=
\sum_{l=1}^L \eta^{\rm adj}_l(x_{\mathcal D},x_{\mathcal D^c};\rho^\ast)\;
\PP^{(l)}_{Y | X}(dy\mid x_{\mathcal D},x_{\mathcal D^c}),
\end{equation*}
where the posterior is
$$
\eta^{\rm adj}_l(x;\rho)
:=
\frac{\rho_l\, p^{(l)}(x_{\mathcal D^c}\mid x_{\mathcal D})}
{\sum_{k=1}^L \rho_k\, p^{(k)}(x_{\mathcal D^c}\mid x_{\mathcal D})}.
$$
Thus, if \eqref{eq:cond-joint} holds, then $\PP^{(0)}_{Y | X}$ is identifiable even without observing $Y^{(0)}$.


As in the original DORM construction, when $\rho^\ast$ is unknown and when the adjusted fully coupling \eqref{eq:cond-joint} may fail, we define an \emph{adjusted prior} $\bar\rho_{\rm adj}$ by projecting the target \emph{conditional} covariate law $\PP^{(0)}_{X_{\mathcal D^c}\mid X_{\mathcal D}}$ onto the convex hull of the source conditionals $\{\PP^{(l)}_{X_{\mathcal D^c}\mid X_{\mathcal D}}\}_{l=1}^L$ in KL divergence:
\begin{align}
\bar\rho_{\rm adj}
&:=
\arg\min_{\rho\in\Delta_L}\;
\EE_{X_{\mathcal D}\sim\PP^{(0)}_{X_{\mathcal D}}}
\Big[
D_{\mathrm{KL}}\Big(
\PP^{(0)}_{X_{\mathcal D^c}\mid X_{\mathcal D}}(\cdot\mid X_{\mathcal D})
\ \Big\|\ 
\sum_{l=1}^L \rho_l\,\PP^{(l)}_{X_{\mathcal D^c}\mid X_{\mathcal D}}(\cdot\mid X_{\mathcal D})
\Big)
\Big]
\nonumber\\
&=
\arg\max_{\rho\in\Delta_L}\;
\EE_{(X_{\mathcal D},X_{\mathcal D^c})\sim \PP^{(0)}_{X}}
\left[
\log\Big\{
\sum_{l=1}^L \rho_l\, p^{(l)}(X_{\mathcal D^c}\mid X_{\mathcal D})
\Big\}
\right].
\label{eq:rho-bar-adj-pop}
\end{align}
When \eqref{eq:cond-joint} holds, the optimizer satisfies $\bar\rho_{\rm adj}=\rho^\ast$. Given $\bar\rho_{\rm adj}$, define the \emph{population adjusted posterior weights}
\begin{equation*}
\bar\eta^{\rm adj}_l(x_{\mathcal D},x_{\mathcal D^c})
:=
\eta^{\rm adj}_l(x_{\mathcal D},x_{\mathcal D^c};\bar\rho_{\rm adj})
=
\frac{\bar\rho_{{\rm adj},l}\, p^{(l)}(x_{\mathcal D^c}\mid x_{\mathcal D})}
{\sum_{k=1}^L \bar\rho_{{\rm adj},k}\, p^{(k)}(x_{\mathcal D^c}\mid x_{\mathcal D})}.
\label{eq:eta-bar-adj-pop}
\end{equation*}
Equivalently, in terms of (source/target) conditional density ratios
\begin{equation*}
\bar r^{\rm adj}_l(x_{\mathcal D},x_{\mathcal D^c})
:=
\frac{\mathrm{d} \PP^{(l)}_{X_{\mathcal D^c}\mid X_{\mathcal D}}}{\mathrm{d} \PP^{(0)}_{X_{\mathcal D^c}\mid X_{\mathcal D}}}(x_{\mathcal D^c}\mid x_{\mathcal D}),
\qquad
\bar\eta^{\rm adj}_l(x)
=
\frac{\bar\rho_{{\rm adj},l}\,\bar r^{\rm adj}_l(x)}
{\sum_{k=1}^L \bar\rho_{{\rm adj},k}\,\bar r^{\rm adj}_k(x)}.
\label{eq:eta-bar-adj-ratio}
\end{equation*}
To connect with estimable ratios, define the (target/source) marginal ratios
\[
\bar w_l(x):=\frac{\mathrm{d} \PP^{(0)}_{X}}{\mathrm{d} \PP^{(l)}_{X}}(x),
\qquad
\bar v_l(x_{\mathcal D}):=\frac{\mathrm{d} \PP^{(0)}_{X_{\mathcal D}}}{\mathrm{d} \PP^{(l)}_{X_{\mathcal D}}}(x_{\mathcal D}).
\]
Then the identity \eqref{eq:cond_dr} in the main text implies
\begin{equation}
\frac{\mathrm{d} \PP^{(0)}_{X_{\mathcal D^c}\mid X_{\mathcal D}}}{\mathrm{d} \PP^{(l)}_{X_{\mathcal D^c}\mid X_{\mathcal D}}}(x_{\mathcal D^c}\mid x_{\mathcal D})
=
\frac{\bar w_l(x_{\mathcal D},x_{\mathcal D^c})}{\bar v_l(x_{\mathcal D})},
\qquad\text{hence}\qquad
\bar r^{\rm adj}_l(x_{\mathcal D},x_{\mathcal D^c})
=
\frac{\bar v_l(x_{\mathcal D})}{\bar w_l(x_{\mathcal D},x_{\mathcal D^c})}.
\label{eq:rbar-adj-vw}
\end{equation}

Define the \emph{adjusted coupled reference conditional} induced by $\bar\eta^{\rm adj}$:
\begin{equation*}
\bar T^{\rm adj}_{Y | X}(dy\mid x)
:=
\sum_{l=1}^L \bar\eta^{\rm adj}_l(x)\;\PP^{(l)}_{Y | X}(dy\mid x).
\end{equation*}
Under \eqref{eq:cond-joint}, $\bar T^{\rm adj}_{Y | X}=\PP^{(0)}_{Y | X}$.
Analogously to the original DORM, the adjusted partially $(X,Y)$-coupled regime uses the uncertainty set
\begin{equation*}
\mathcal M_{\rm adj}(s_{\max})
:=
\left\{
\big(\PP^{(0)}_{X},\, T^{\rm adj}_{Y | X}(s,\delta)\big)
:\ \delta\in\Delta_L,\ s\in[0,s_{\max}]
\right\},
\label{eq:Madj}
\end{equation*}
where
$$
T^{\rm adj}_{Y | X}(s,\delta)
:=
\sum_{l=1}^L\Big[(1-s)\bar\eta^{\rm adj}_l(X)+s\,\delta_l\Big]\PP^{(l)}_{Y | X}.
$$
With the same reward $R_P(\beta)=\EE_{(X,Y)\sim P}\big[Y^2-(Y-A^\top\beta)^2\big]$, define the population adjusted DORM target
\begin{equation}
\bar\beta^{\rm adj}_{\rm DO}(s_{\max})
:=
\arg\max_{\beta\in\RR^q}\ \min_{P\in\mathcal M_{\rm adj}(s_{\max})} R_P(\beta).
\label{eq:betaDO-adj-pop}
\end{equation}
By the same argument as Theorem~\ref{thm:PopuIdenti} in the main text, \eqref{eq:betaDO-adj-pop} admits the explicit form
\begin{equation*}
\bar\beta^{\rm adj}_{\rm DO}(s_{\max})
=
\sum_{l=1}^L \gamma^{\ast,{\rm adj}}_l\,\bar\beta_l
+
\gamma^{\ast,{\rm adj}}_{\rm mix}\,\bar\beta^{\rm adj}_{\rm mix},
\qquad
\gamma^{\ast,{\rm adj}}
\in
\arg\min_{\gamma\in S(s_{\max})}\ \gamma^\top \Gamma^{\rm adj}\gamma,
\label{eq:betaDO-adj-decomp}
\end{equation*}
where $S(s_{\max})=\{\gamma\in\Delta_{L+1}:\gamma_{\rm mix}\in[1-s_{\max},1]\}$, $\bar\beta_l$ is the (counterfactual) least-squares coefficient under $(\PP^{(0)}_X,\PP^{(l)}_{Y | X})$,
\begin{equation*}
\bar\beta_l
:=
\arg\min_{\beta\in\RR^q}\ \EE_{(X,Y)\sim(\PP^{(0)}_X,\PP^{(l)}_{Y | X})}\big(Y-A^\top\beta\big)^2,
\qquad l\in[L],
\label{eq:beta-l-pop}
\end{equation*}
and $\bar\beta^{\rm adj}_{\rm mix}$ is the coupled (adjusted joint-mixing) least-squares coefficient under $(\PP^{(0)}_X,\bar T^{\rm adj}_{Y | X})$:
\begin{equation*}
\bar\beta^{\rm adj}_{\rm mix}
:=
\arg\min_{\beta\in\RR^q}\ \EE_{(X,Y)\sim(\PP^{(0)}_X,\bar T^{\rm adj}_{Y | X})}\big(Y-A^\top\beta\big)^2.
\label{eq:beta-mix-adj-pop}
\end{equation*}
Let $\bar\Sigma^{(0)}:=\EE_{\PP^{(0)}_X}[AA^\top]$ and $\bar m_l(x):=\EE_{\PP^{(l)}_{Y | X}}[Y\mid X=x]$. Then
\begin{equation*}
\bar\beta_l=(\bar\Sigma^{(0)})^{-1}\EE_0\big[\bar m_l(X)A\big],
\qquad
\bar\beta^{\rm adj}_{\rm mix}
=
(\bar\Sigma^{(0)})^{-1}\sum_{l=1}^L \EE_0\big[\bar\eta^{\rm adj}_l(X)\,\bar m_l(X)\,A\big].
\label{eq:beta-pop-closed}
\end{equation*}
Finally, $\Gamma^{\rm adj}=(\Gamma^{\rm adj}_{jk})_{j,k\in[L+1]}$ is defined by
\begin{equation*}
\Gamma^{\rm adj}_{jk}:=\bar\beta_j^\top \bar\Sigma^{(0)}\bar\beta_k,
\quad j,k\in[L+1],
\qquad
\text{with the convention }\ \bar\beta_{L+1}:=\bar\beta^{\rm adj}_{\rm mix}.
\label{eq:Gamma-adj-pop}
\end{equation*}

Let $\widehat{\mathcal{P}}_0$ be the empirical mean over the (unlabeled) target sample $D_0$, and $\widehat{\mathcal{P}}_l$ be the empirical mean over the labeled sample from source $l$ (as in Section~3). Estimate $\bar w_l$ with the same density-ratio learner as in the original DORM, yielding $\hat w_l(x)\approx \bar w_l(x)$. Estimate $\bar v_l$ analogously using only features in $X_{\mathcal D}$, yielding $\hat v_l(x_{\mathcal D})\approx \bar v_l(x_{\mathcal D})$. Define the estimated (source/target) conditional ratio using \eqref{eq:rbar-adj-vw}:
\begin{equation*}
\hat r^{\rm adj}_l(x_{\mathcal D},x_{\mathcal D^c})
:=
\frac{\hat v_l(x_{\mathcal D})}{\hat w_l(x_{\mathcal D},x_{\mathcal D^c})}.
\label{eq:rhat-adj}
\end{equation*}
The empirical analog of \eqref{eq:rho-bar-adj-pop} is the concave maximization
\begin{equation*}
\hat\rho_{\rm adj}
\in
\arg\max_{\rho\in\Delta_L}
\ \widehat{\mathcal{P}}_0\!\left[
\log\!\Big(\sum_{l=1}^L \rho_l\,\hat r^{\rm adj}_l(X)\Big)
\right]
+\lambda\|\rho\|_2^2,
\label{eq:rhohat-adj}
\end{equation*}
and the resulting estimated adjusted posterior weights are
\begin{equation*}
\hat\eta^{\rm adj}_l(x)
=
\frac{\hat\rho_{{\rm adj},l}\,\hat r^{\rm adj}_l(x)}
{\sum_{k=1}^L \hat\rho_{{\rm adj},k}\,\hat r^{\rm adj}_k(x)}.
\label{eq:etahat-adj}
\end{equation*}
Next, estimate $\bar m_l$ by any regression learner trained on labeled source-$l$ data, denoted $\hat m_l$ (cross-fitting can be applied exactly as in Appendix~\ref{sec:app:cross-details}). Let
\begin{equation*}
\hat\Sigma^{(0)}:=\widehat{\mathcal{P}}_0\big[AA^\top\big].
\label{eq:Sigmahat0}
\end{equation*}
Define the plug-in estimators
\begin{equation*}
\tilde\beta_l
:=
(\hat\Sigma^{(0)})^{-1}\widehat{\mathcal{P}}_0\big[\hat m_l(X)A\big],
\qquad l\in[L],
\qquad
\tilde\beta^{\rm adj}_{\rm mix}
:=
(\hat\Sigma^{(0)})^{-1}\widehat{\mathcal{P}}_0\Big[\sum_{l=1}^L \hat\eta^{\rm adj}_l(X)\,\hat m_l(X)\,A\Big].
\label{eq:beta-tilde-adj}
\end{equation*}
The doubly robust/DML estimators are
\begin{equation*}
\hat\beta_l
=
\tilde\beta_l
+
(\hat\Sigma^{(0)})^{-1}\widehat{\mathcal{P}}_l\!\Big[\hat w_l(X)\big\{Y-\hat m_l(X)\big\}A\Big],
\qquad l\in[L],
\label{eq:beta-hat-l-adj}
\end{equation*}
and
\begin{equation*}
\hat\beta^{\rm adj}_{\rm mix}
=
\tilde\beta^{\rm adj}_{\rm mix}
+
(\hat\Sigma^{(0)})^{-1}\sum_{l=1}^L
\widehat{\mathcal{P}}_l\!\Big[\hat\eta^{\rm adj}_l(X)\,\hat w_l(X)\big\{Y-\hat m_l(X)\big\}A\Big].
\label{eq:beta-hat-mix-adj}
\end{equation*}
Set $\hat\beta_{L+1}:=\hat\beta^{\rm adj}_{\rm mix}$ and compute
\begin{equation*}
\hat\Gamma_{jk}:=\hat\beta_j^\top \hat\Sigma^{(0)}\hat\beta_k,
\qquad j,k\in[L+1].
\label{eq:Gammahat-adj}
\end{equation*}
For a given decoupling budget $s_{\max}$, solve the same quadratic program:
\begin{equation*}
\hat\gamma^{\rm adj}
\in
\arg\min_{\gamma\in \mathcal{S}(s_{\max})}\ \gamma^\top \hat\Gamma\,\gamma,
\qquad
\mathcal{S}(s_{\max})=\{\gamma\in\Delta_{L+1}:\gamma_{\rm mix}\in[1-s_{\max},1]\},
\label{eq:gammahat-adj}
\end{equation*}
and output the adjusted DORM estimator
\begin{equation*}
\hat\beta^{\rm adj}_{\rm DO}(s_{\max})
=
\sum_{l=1}^L \hat\gamma^{\rm adj}_l\,\hat\beta_l
+
\hat\gamma^{\rm adj}_{\rm mix}\,\hat\beta^{\rm adj}_{\rm mix}.
\label{eq:betaDOhat-adj}
\end{equation*}
In practice, $s_{\max}$ can be tuned by the same side-information strategy in Section~\ref{sec:tuning}, with $\hat\beta^{\rm adj}_{\rm DO}(s_{\max})$ replacing $\hat\beta_{\rm DO}(s_{\max})$ throughout.


\section{Proofs}

\subsection{Theoretical Assumptions}
\label{subsec:assum}
\begin{assumption}
There exists some constant $C_1>0$ such that $\EE_lY^2<C_1$, $C_1\inv \leqslant \lambda_{\min}(\bar\Sigma\uz) \leqslant \lambda_{\max}(\bar\Sigma\uz) \leqslant C_1$, and $C_1\inv \leqslant \lambda_{\min}(\bar\Omega(\bar\rho)) \leqslant \lambda_{\max}(\bar\Omega(\bar\rho)) \leqslant C_1$. Covariates $A\uz$ has finite fourth moments $\EE_0 \|A\|_2^4 < \infty$.
\label{assum:1}
\end{assumption}


\begin{assumption}
\label{assum:bound}
There exists some absolute constant $C_2>0$ such that 
\begin{equation*}
    \max\limits_{l \in[L],~k\in \{0,l\}} \| \bar{m}_l \|_{A,k}+{\|\bar{w}_l \|_{A,k} } \leqslant C_2,\quad \max\limits_{l \in [L+1]} \|\bar{\beta}_l\|_2 \leqslant C_2,\mbox{ where }~\bar{\beta}_{L+1}=\bar{\beta}_{\mix}.
\end{equation*}
\end{assumption}

\begin{assumption}(Overlap) There exists some constant $C_w$ such that for $\forall l \in [L]$ and $x$, $0<C_w\inv < \wlb(x) < C_w$, $C_w\inv<\bar{r}_l(x)<C_w$.
\label{assum:overlap}
\end{assumption}

\begin{assumption}
\label{assum:rate} 
There exists sequences $\Delta^{r}(n)$, $\Delta^{w}(n)$ and $\Delta^{m}(n)$ that converge to $0$ as $n\rightarrow\infty$, and satisfy
\begin{align*}
\max\limits_{k\in \{0,l\}} \left\|\mlh - \bar{m}_l\right\|_{A,k} &\lesssim_{\sf P} \Delta^{m}(n_l);\\
\max\limits_{k\in \{0,l\}} \left\|\wlh - \bar{w}_l\right\|_{A,k} + \left\|\wlh - \bar{w}_l\right\|_{2,k} &\lesssim_{\sf P} \Delta^{w}(N_0\wedge N_l);\\
\max\limits_{k\in \{0,l\}} \left\|\widehat{r} - \bar{r}\right\|_{2,k}\ &\lesssim_{\sf P} \Delta^{r}(N_{[L]}).
\end{align*}
\end{assumption}


\subsection{Proof of Proposition \ref{propo:conmodel}}
\textbf{Proof.} 
We notice that the joint distribution is a mixture: 
\begin{equation*}
    (\mathbb{P}\xz,\mathbb{P}_{Y \mid X}\uz) =\suml \rho_l^* \mathbb{P}\ul= \suml \rho_l^* (\mathbb{P}^{(l)}_{X},\mathbb{P}^{(l)}_{Y | X}),
\end{equation*} 
This implies the marginal distribution of $X$ on the target to be
\begin{equation*}
    \PP\uz_X = \suml \rho^*_l \PP_X\ul \sim \text{Mix}(x,\rho^*).
\end{equation*}
by the definition. Let $S$ be the latent indicator of source for the subject, then by total probability, we have that on the target
\begin{align*}
    \PP\uz_{Y|X} & = \suml \PP_{(X,Y)\sim (\mathbb{P}\xz,\mathbb{P}_{Y \mid X}\uz)}(Y|X,S=l)\PP_{X\sim \mathbb{P}\xz}(S=l|X) \\
    & = \suml \PP\ul_{Y|X} \PP_{\Mix(\rho^*)}(S=l|X) = \suml \eta_l(x;\rho^*) \PP\ul_{Y|X}.
\end{align*}
And by the Bayes formula, we have
\begin{align*}
    \eta_l(x;\rho) & = \PP_{\Mix(\rho^*)}(S=l|X)  = \frac{\PP_{\Mix(\rho^*)}(X|S=l)\PP_{\Mix(\rho^*)}(S=l)}{\sum_{k=1}^L \PP_{\Mix(\rho^*)}(X|S=k)\PP_{\Mix(\rho^*)}(S=k)} \\
    & = \frac{\rho_l \mathrm{d} \PP^{(l)}_X(X)}{\sum_{k=1}^L\rho_k \mathrm{d} \PP^{(k)}_X(X)}.
\end{align*}
\qed

\subsection{Proof of Proposition \ref{propo:Doubly}}
\textbf{Proof.} 
For $\blh$, we have $\forall l \in [L]$,
\begin{align*}
    \qlh(w_l,m_l) & = (\szh)\inv \cpzh m_l(X_i\uz) A_i\uz + \cplh w_l(X^{(l)}_i) [Y^{(l)}_i-m_l(X^{(l)}_i)] (\szh)^{-1} A\ul_i
\end{align*}
Let sample size $n := N_0 \wedge \{\min_{1\leqslant i\leqslant L} n_i\} \to \infty$, then by law of large number and Slutsky Theorem we have
\begin{align*}
    \lim_{n \to \infty} \qlh(w_l,m_l) & = (\bar{\Sigma}\uz)\inv \EE_0 m_l(X_i\uz) A_i\uz + \EE_l w_l(X^{(l)}_i) [Y^{(l)}_i-m_l(X^{(l)}_i)] (\bar\Sigma\uz)^{-1} A\ul_i
\end{align*}
If $w_l = \bar{w_l}$ and $m_l$ is an arbitrary model, then by definition of density ratio we have
\begin{align*}
    \lim_{n \to \infty} \qlh(\bar w_l,m_l) & = (\bar{\Sigma}\uz)\inv \EE_0 m_l(X_i\uz) A_i\uz + \EE_l \bar w_l(X^{(l)}) [\bar{m}_l(X\ul)-m_l(X^{(l)})] (\bar\Sigma\uz)^{-1} A\ul \\ 
    & = (\bar{\Sigma}\uz)\inv \EE_0 m_l(X_i\uz) A_i\uz + \EE_0 [\bar{m}_l(X\uz)-m_l(X^{(0)})] (\bar\Sigma\uz)^{-1} A\uz \\ 
    & = (\bar\Sigma\uz)^{-1} \EE_0 {m}_l(X\uz) A\uz = \bar\beta_l.
\end{align*}
If $m_l=\bar m_l$ and $w_l$ is an arbitrary model, by conditioning on $X\ul$ in the second part, 
\begin{align*}
    \lim_{n \to \infty} \qlh(w_l,\bar m_l) & = (\bar{\Sigma}\uz)\inv \EE_0 \bar m_l(X_i\uz) A_i\uz + \EE_l w_l(X^{(l)}) [\bar{m}_l(X\ul)-\bar{m}_l(X^{(l)})] (\bar\Sigma\uz)^{-1} A\ul \\ 
    & = (\bar\Sigma\uz)^{-1} \EE_0 \bar{m}_l(X\uz) A\uz + 0 = \bar\beta_l.
\end{align*}
And this gives the doubly robust property of $\blh$.
For $\ph$, we have
\begin{align*}
    \ph(\bar\eta_l,w_l,m_l) = & (\szh)\inv  \suml \cpzh\bar\eta_l(X_i\uz)  m_l(X_i\uz) A_i\uz \\
    & + \suml \cplh \bar\eta_l(X\ul_i) w_l(X^{(l)}_i) [Y^{(l)}_i -m_l(X^{(l)}_i)] (\szh)^{-1} A\ul_i,
\end{align*}
and the proof follows the similar spirit of $\qlh$. Let sample size $n := N_0 \wedge \{\min_{1\leqslant i\leqslant L} n_i\} \to \infty$, then by law of large number and Slutsky Theorem we have
\begin{align*}
    \lim_{n\to\infty} \ph(\bar\eta_l,w_l,m_l) = & (\bar\Sigma\uz)\inv  \suml \EE_0 \bar\eta_l(X_i\uz)  m_l(X_i\uz) A_i\uz \\
    & + \suml \EE_l \bar\eta_l(X\ul_i) w_l(X^{(l)}_i) [Y^{(l)}_i -m_l(X^{(l)}_i)] (\bar{\Sigma}\uz)^{-1} A\ul_i,
\end{align*}
If $w_l = \bar{w_l}$ and $m_l$ is an arbitrary model, 
\begin{align*}
    \lim_{n\to\infty} \ph(\bar\eta_l,\bar w_l,m_l) = & (\bar\Sigma\uz)\inv  \suml \EE_0 \bar\eta_l(X_i\uz)  m_l(X_i\uz) A_i\uz \\
    & + \suml \EE_l \bar\eta_l(X\ul_i) \bar w_l(X^{(l)}_i) [\bar m_l(X^{(l)}) -m_l(X^{(l)}_i)] (\bar{\Sigma}\uz)^{-1} A\ul_i\\
    = & (\bar\Sigma\uz)\inv  \suml \EE_0 \bar\eta_l(X_i\uz)  m_l(X_i\uz) A_i\uz \\
    & + \suml \EE_0 \bar\eta_0(X\uz_i) [\bar m_l(X^{(0)}) -m_l(X^{(0)}_i)] (\bar{\Sigma}\uz)^{-1} A\ul_i \\
    = & (\bar\Sigma\uz)^{-1} \suml \EE_0 \bar\eta_l(X\uz)\bar{m}_l(X) A\uz = \widetilde{\beta}_{L+1}.
\end{align*}
If $m_l = \bar m_l$ and $w_l$ is an arbitrary model, then by conditioning on different $X\uz$, the second part vanishes and also gives doubly robust property of $\ph$. 
 \qed

% \subsection{Proof of Proposition \ref{propo:A-norm}}
% \noindent \textbf{Proof.} Positiveness: If $\|f\|_{A,l} = 0$, then $\EE_l \sumq f(X)^2 A_k^2 = 0$. Because $A$ is continuous,$\{A_k = 0\}$ is zero probability, therefore we know that $f = 0$ almost surely on the support of $X\ul$.

