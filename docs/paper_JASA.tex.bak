% \begin{align*}
%     \|f + g\|_{A,l} = & \big(\EE_l \| f(X) A + g(X) A\|_2^2\big)^{1/2} \\
%     = & \|f(X)A+g(X)A\|_{L_2} \leqslant \|f(X)A\|_{L_2}+\|g(X)A\|_{L_2} \\
%     = & \big(\EE_l \| f(X) A \|_2^2\big)^{1/2}+\big(\EE_l \|g(X) A\|_2^2\big)^{1/2} = \|f \|_{A,l} + \|g\|_{A,l}
% \end{align*}
% Therefore, the function $\|\cdot\|_{A,l}$ defined in (\ref{eq:A-norm}) is a norm on the space of measurable functions on the support of $X\ul$. \qed

\subsection{Proof of Theorem \ref{thm:PopuIdenti}}
\textbf{Proof.} The main idea of this proof follows \cite{meinshausen2015maximin}.
Optimization problem (\ref{eq:droY}) can be written as:
\begin{align*}
 \barbetare(\smax) & =\underset{\beta \in \mathbb{R}^q}{\arg \max } \min _{\PP \in \uncer} R_{\PP}(\beta) \\
 & = \underset{\beta \in \mathbb{R}^q}{\arg \max } \min _{\PP \in \uncer} \mathbb{E}_{(X, Y) \sim \PP}\left[Y^2-(Y-{ A\trans \beta})^2\right]
\end{align*}
We can expand some distribution $\PP$ in the uncertainty set $\uncer$ as 
\begin{align*}
    \PP = \left(\PP_X\uz,(1-s)\sum_{l=1}^L \bar\eta_l(X) \mathbb{P}_{Y \mid X}^{(l)}+ s \sum_{l=1}^L \delta_l \mathbb{P}_{Y \mid X}^{(l)} \right)
\end{align*}
Therefore, the objective function can be expressed as:
\begin{align}
    \mathbb{E}_{(X, Y) \sim \PP}\left[Y^2-(Y-{ A\trans \beta})^2\right] & = \mathbb{E}_{(X, Y) \sim \PP}\left[-\beta\trans AA\trans \beta + 2\beta\trans AY \right] \notag\\
    & = \EE_{X\sim \PP\uz_X} \EE_{Y|X} \left(-\beta\trans AA\trans \beta + 2\beta\trans AY \right) \notag\\
    & = -\beta\trans (\EE_0 AA\trans) \beta + 2\beta\trans \EE_{X\sim \PP\uz_X} \EE_{Y|X} (AY). \label{appen:thm1:1}
\end{align}
Notice that
\begin{align}
    \EE_{X\sim \PP\uz_X} \EE_{Y|X} (AY) & = \EE_0 \left[ (1-s)\suml \bar\eta_l(X)\bar m_l(X)A + s \suml \delta_l \bar m_l(X)A \right] \notag \\
    & = (\bar\Sigma\uz) \left[ (1-s) (\bar\Sigma\uz)\inv \suml \EE_0 \bar\eta_l(X)\bar m_l(X)A + s \suml \delta_l (\bar\Sigma\uz)\inv \EE_0 \bar m_l(X)A \right] \notag \\
    & = (\bar\Sigma\uz) \left[(1-s)\bar\beta^\mix + s\suml\delta_l \bar{\beta}_l \right], \label{appen:thm1:2}
\end{align}
where $\delta = (\delta_1,\cdots,\delta_L)\trans, \delta \in \Delta_L$. Let 
\begin{align}
    \BB = & \ \{ b=(1-s) \bar\beta^\mix+ s\suml\delta_l \bar{\beta}_l \in \mathbb{R}^p \mid \delta \in \Delta_L, s \in [0,\smax]\} \notag \\
    = & \ \{ b = \sumll \gamma_l\bar{\beta}_l \mid \gamma \in \mathcal{S}(\smax) \} \label{appen:thm1:3}
\end{align}
then $\BB$ is a convex and compact set. So by substituting (\ref{appen:thm1:2}) into (\ref{appen:thm1:1}), we can reduce the original quadratic problem (\ref{eq:droY}) as
\begin{equation*}
    \max_{\beta} \min_{b \in \BB} \beta\trans \bar\Sigma\uz \beta -2b\trans \bar\Sigma\uz \beta
\end{equation*}

For $\bar\Sigma\uz$ is of full rank, let $\bar\Sigma\uz=$ $C^{\top} C$ be the Cholesky decomposition of $\bar\Sigma\uz$ such that $C$ is invertible. Note that $\BB$ is a convex and compact set. Define $\widetilde{\mathbb{B}}=C^{-1} \mathbb{B}$. After linear transformation, $\widetilde{\BB}$ is also a convex and compact set. Then we have $\barbetare=C^{-1} \xi^*$ with
\begin{equation}
    \xi^*=\underset{\xi \in \mathbb{R}^p}{\arg \max } \min _{u \in \widetilde{\mathbb{B}}}\left[2 u^{\top} \xi-\xi^{\top} \xi\right]
\label{eq:xistar}
\end{equation}
We are going to show that
\begin{equation*}
    \xi^m=\underset{\xi \in \tilde{\mathbb{B}}}{\arg \min } \xi^{\top} \xi = \underset{\xi \in \tilde{\mathbb{B}}}{\arg \min } \left\|\xi \right\|_2^2.
\end{equation*}
is exactly the solution of (\ref{eq:xistar}), i.e. $\xi^* = \xi^m$. Since $\tilde{\BB}$ is compact, the minimum point $\xi^m$ can be attained in $\tilde{\BB}$.

For any $t \in[0,1]$ and $\mu \in \widetilde{\mathbb{B}}$, we use the convexity of $\tilde{\BB}$ so that $\xi^m+t\left(\mu-\xi^m\right) \in \widetilde{\mathbb{B}}$ for $t \in [0,1]$ and obtain $\left\|\xi^m+t\left(\mu-\xi^m\right)\right\|_2^2 \geqslant \left\|\xi^m\right\|_2^2$. Let
\begin{align*}
    f(t) := & \left\|\xi^m+t\left(\mu-\xi^m\right)\right\|_2^2 \\
    = & (\xi^m)\trans \xi^m +2t(\mu - \xi^m)\trans \xi^m + t^2 (\mu-\xi^m)\trans(\mu-\xi^m)
\end{align*}
$t=0$ is a minimum point of the quadratic function $f(t),t\in [0,1]$, so $f'(0)\geqslant 0$, which leads to 
\begin{equation}
    2\mu\trans \xi^m -(\xi^m)\trans \xi^m \geqslant (\xi^m)\trans \xi^m, \quad \forall \mu \in \tilde{\BB}.
\label{eq:bound11}
\end{equation}
For any $\xi \in \mathbb{R}^p$, using $||\xi - \xi^m ||_2^2 \geqslant 0$, we can get
\begin{equation}
    2(\xi^m)\trans \xi - \xi\trans \xi \leqslant (\xi^m)\trans \xi^m, \quad \forall \xi \in \mathbb{R}^p. 
\label{eq:bound12}
\end{equation}

(\ref{eq:bound12}) means that no matter which $\xi$ we choose, taking $u=\xi^m$ gives a upper bound for $2 u^{\top} \xi-\xi^{\top} \xi$. (\ref{eq:bound11}) means that if we choose $\xi = \xi^m$, then no matter which $u \in  \tilde{\BB}$, we have a lower bound for $2 u^{\top} \xi-\xi^{\top} \xi$. Combined with the above two bounds, we have
\[
 \xi^m=\underset{\xi \in \mathbb{R}^p}{\arg \max } \min _{u \in \widetilde{\mathbb{B}}}\left[2 u^{\top} \xi-\xi^{\top} \xi\right] = \xi^*.
\]

Since $\barbetare=C^{-1} \xi^*$ and $\bar\Sigma\uz=C\trans C$, so we know that the solution $\barbetare$ satisfies 
\begin{equation}
    \barbetare =  \underset{{\beta \in \BB}}{\arg\min} \ \beta\trans \bar\Sigma\uz \beta 
\label{appen:thm1:4}
\end{equation} 
Finally, as every vector in set $\BB$ can be written as in (\ref{appen:thm1:3}) and by substituting into (\ref{appen:thm1:4}) we arrive at the conclusion.  \qed

\subsection{Proof of Lemma \ref{lemma:eta}}
\textbf{Proof.} 
First of all, throughout all following proofs, we assume the independence between nuisance models $\widehat{r}_l,\mlh,\wlh$ and the data $X\ul_j,X\uz_i$. This independence can be created by cross-fitting, and for simplicity we drop the sample splitting notations. Throughout the proofs, we will use subscript $i$ for the observations $\left\{X_i\right\}_{i \in[N_0]}$ in the target data, and use subscript $j$ for the observations $\{(X_j^{(l)}, Y_j^{(l)})\}_{j \in[n_l], l \in[L]}$ in the source data. 
\subsubsection*{Part I: Convergence rate of $\widehat\rho$}
First, we need to obtain the rate of $\widehat{\rho}$. Recall that 
\begin{equation*}
    \widehat{\rho} = \underset{\rho \in \Delta_L}{\arg\min}\ -\cpzh \log\left\{\sum_{l=1}^L \rho_l \widehat{r_l}(X\uz_i)\right\}  + \lambda \| \rho\|_2^2 =: \underset{\rho \in \Delta_L}{\arg\min}\ L_n(\rho).
\end{equation*}
and
\begin{equation*}
    \bar{\rho} = \underset{\rho \in \Delta_L}{\arg\min}\ -\EE_0 \log\left\{\sum_{l=1}^L \rho_l \bar{r}_l(X)\right\} =: \underset{\rho \in \Delta_L}{\arg\min}\ L(\rho).
    \label{appen:rhobar}
\end{equation*}
we can see that $\widehat{\rho}$ is a two-step M-estimator for the true parameter $\bar\rho$. In fact there should be a subscript for $\widehat{\rho} = \widehat{\rho}_n$, which we omitted here for simplicity. The reader should keep in mind that $\widehat{\rho}$ varies with $n=N_0$. 
% We can define an intermediate estimator $\bar{\rho}$ as
% \begin{equation}
%     \widetilde{\rho} = \underset{\rho \in \Delta_L}{\arg\min}\ -\cpzh \log\left\{\sum_{l=1}^L \rho_l {\bar{r}_l(X\uz_i)}\right\} 
%     \label{appen:rhotilde}
% \end{equation}
As $-\log x$ is a convex function and $\sum_{l=1}^L \rho_l \widehat{r_l}(X\uz_i)$ is linear in $\rho$, $L(\rho)$ and $L_n(\rho)$ are both convex functions in $\rho \in \Delta_L$. 

\begin{lemma} (First-order property of convex function) Let $f$ be convex and $\mathcal{X}$ a closed convex set on which $f$ is differentiable. If
$
x^* \in \operatorname{argmin}_{x\in\mathcal{X}} f(x),
$
then
$
\nabla f\left(x^*\right)^{\top}\left(y-x^*\right) \geqslant 0, \forall y \in \mathcal{X}.
$
\label{lemma:firstorder}
\end{lemma}

\noindent \textbf{Proof of Lemma \ref{lemma:firstorder}.} Let $\phi (t) := f(x^*+t(y-x^*)), t\in [0,1]$. Then from $
x^* \in \operatorname{argmin}_{x\in\mathcal{X}} f(x),
$ we know that $t=0$ is the minimum of $\phi(t)$. As $f$ is differentiable, $\phi(t)$ is also differentiable, thus $\phi'(0)\geqslant 0$, which is $\nabla f(x^*)\trans(y-x^*) \geqslant 0$. \qed  


\begin{lemma}{(Chebyshev Inequality for $L_2$-norm of random vector)}
For i.i.d $q$-dimensional random vectors $X_1,...,X_n, X_i= (X_{i,1},\cdots,X_{i,q})$, we define mean vector $\bar{X} = \frac{1}{n}\sum_{i=1}^n X_i$. Then for any $t\geqslant 0$, we have 
\begin{equation}
    \|\bar{X}-\EE X\|_2 \lessp \sqrt{\frac{\EE X\trans X}{n}}.
    \label{appen:cheby}
\end{equation}
\label{lemma:Chebyshev}
\end{lemma}
\noindent \textbf{Proof of Lemma \ref{lemma:Chebyshev}.} Using one dimensional Markov inequality we have: 
\begin{align*}
\PP (\|\bar{X}-\EE X\|_2 \geqslant t ) = & \PP (\|\bar{X}-\EE X\|_2^2 \geqslant t^2 ) = \PP (\sumq (\bar{X}_{i,k}-\EE X_{i,k})_2^2 \geqslant t^2 ) \\
\leqslant & \frac{\sumq \Var \bar{X}_{i,k}}{t^2} = \frac{\sumq \Var X_{i,k}}{nt^2} \leqslant \frac{\EE \sumq X_{i,k}^2}{nt^2} = \frac{\EE X\trans X}{nt^2}.
\end{align*}
Taking $t=a\sqrt{\frac{\EE X\trans X}{n}}$ and setting $a\to 0$ gives us the conclusion.
\qed

First we establish consistency for $\widehat{\rho} \to \bar\rho$. From the definition we have inequality
\begin{equation*}
    L_n(\widehat{\rho}) \leqslant L_n(\bar\rho).
    \label{appen:zerorder}
\end{equation*}
Notice that $\widehat{\rho} = \widehat{\rho}_n$ is on the simplex $\Delta_L$, thus bounded, so there exists a convergent subsequence $\{\widehat{\rho}_{n_k}\}$. For any convergent subsequence $\{\widehat{\rho}_{n_k}\}$ from sequence $\{\widehat{\rho}_n\}$, we take limit as $k\to\infty$. Assuming $\widehat{\rho}_{n_k} \to \tilde{\rho}$, according to the uniform law of large number, and the choice of tuning parameter $\lambda = O(N_0^{-1/2})$, we have $L_{n_k}(\bar{\rho}) \to L(\bar\rho)$ and $\lim_{k\to\infty} L_{n_k}(\widehat{\rho}_{n_k}) = L(\tilde{\rho})$, thus
\begin{equation*}
    L(\tilde{\rho}) = \lim_{k\to\infty} L_{n_k}(\widehat{\rho}_{n_k}) \leqslant \lim_{k\to\infty} L_{n_k}(\bar\rho) = L(\bar\rho)
\end{equation*}
From the uniqueness of mininum of convex function $L(\rho)$, we have $\widehat{\rho}_{n_k} \to \bar\rho$ for any convergent subsequence. Thus $\widehat{\rho} \to \bar\rho$ as $n\to\infty$.

Using first-order property of the convex function. we have
\begin{equation}
    \nabla L(\bar\rho) \trans (\widehat{\rho}-\bar\rho) \geqslant 0
    \label{appen:1order1}
\end{equation}
and
\begin{equation}
    \nabla L_n(\widehat\rho) \trans (\bar{\rho}-\widehat\rho) \geqslant 0
    \label{appen:1order2}
\end{equation}
Because
\begin{equation*}
    \nabla L_n(\widehat\rho) \trans (\bar{\rho}-\widehat\rho) = \nabla L_n(\bar\rho) \trans (\bar{\rho}-\widehat\rho) + (\nabla L_n(\widehat\rho) - \nabla L_n(\bar\rho))\trans (\bar{\rho}-\widehat\rho),
\end{equation*}
from (\ref{appen:1order2}) we get 
\begin{align}
    \nabla L_n(\bar\rho) \trans (\bar{\rho}-\widehat\rho) \geqslant & (\nabla L_n(\bar\rho) - \nabla L_n(\widehat\rho))\trans (\bar{\rho}-\widehat\rho) \notag \\
    = &\ (\bar{\rho}-\widehat\rho)\trans \nabla^2 L_n(\rho_{mid}) (\bar{\rho}-\widehat\rho)
    \label{appen:rrr}
\end{align}
where $\rho_{mid} = \widehat\rho + t(\bar{\rho}-\widehat\rho), t \in [0,1].$ And the LHS of inequality (\ref{appen:rrr}) can be controlled using (\ref{appen:1order1})
\begin{equation}
    \nabla L_n(\bar\rho) \trans (\bar{\rho}-\widehat\rho) \leqslant (\nabla L_n(\bar\rho) - \nabla L(\bar{\rho})) \trans (\bar{\rho}-\widehat\rho)
\label{appen:lll}
\end{equation}
Combining (\ref{appen:rrr}) and (\ref{appen:lll}) we have
\begin{equation}
    (\bar{\rho}-\widehat\rho)\trans \nabla^2 L_n(\rho_{mid}) (\bar{\rho}-\widehat\rho) \leqslant (\nabla L_n(\bar\rho) - \nabla L(\bar{\rho})) \trans (\bar{\rho}-\widehat\rho)
    \label{appen:a11}
\end{equation}
Because in Assumption \ref{assum:rate} we assumed consistency of nuisance model $\widehat{r} \to \bar{r}$, combined with law of large numbers we have $\nabla^2L_n(\rho) \to \nabla^2L(\rho) = \bar{\Omega}(\rho)$ for any given $\rho \in \Delta_L$. In Assumption \ref{assum:1} we have $\lambda_{\min}(\bar\Omega(\bar\rho)) \geqslant C_1\inv$. From Weyl's inequality, $\lambda_{\min} (A)$ is a continuous function with respect to $A$, thus $\lambda_{\min}(\bar\Omega(\rho))$ is a continuous function with respect to $\rho$. Therefore by continuity there exists a neighborhood of $\bar\rho$, denoted by $D_\delta(\bar\rho)$, such that $\forall \rho \in D_{\delta}(\bar\rho), \lambda_{\min}(\bar\Omega(\rho)) \geqslant \frac12 C_1\inv.$ As $\widehat{\rho}\to\bar\rho$, we also have $\rho_{mid} \to \bar{\rho}$. When $n = N_0$ is sufficiently large, $\rho_{mid} \in D_\delta(\bar\rho)$, and $\|\nabla^2L_n(\bar\rho) - \nabla^2L(\bar\rho) \| \leqslant \frac14C_1\inv$ ,which leads (\ref{appen:a11}) to
\begin{equation*}
    \frac{1}{4}C_1\inv \|\widehat{\rho}-\bar\rho\|_2^2 \leqslant \|\nabla L(\bar\rho) - \nabla L_n(\bar{\rho})\|_2  \|\widehat{\rho}-\bar\rho\|_2. 
\end{equation*}
And this is equivalent to
\begin{equation}
    \|\widehat{\rho}-\bar\rho\|_2 \lesssim \|\nabla L(\bar\rho) - \nabla L_n(\bar{\rho})\|_2.
\label{appen:dis0}
\end{equation}
Because $$\nabla L(\rho) = -\EE_0 \dfrac{\bar{r}(X)}{\rho\trans \bar{r}(X)}$$ where $r(X)= (r_1(X),\cdots,r_L(X))$, $$\nabla L_n(\rho) = -\cpzh \dfrac{\widehat{r}(X\uz_i)}{\rho\trans\widehat{r}(X\uz_i)} + 2\lambda \rho,$$
we have
\begin{equation}
    \nabla L(\bar\rho) - \nabla L_n(\bar{\rho}) = -\EE_0 \dfrac{\bar{r}(X)}{\bar\rho\trans \bar{r}(X)} + \cpzh \dfrac{\bar{r}(X\uz_i)}{\bar\rho\trans \bar{r}(X\uz_i)} - \cpzh \dfrac{\bar{r}(X\uz_i)}{\bar\rho\trans \bar{r}(X\uz_i)} + \cpzh \dfrac{\widehat{r}(X\uz_i)}{\bar\rho\trans\widehat{r}(X\uz_i)} - 2\lambda\bar\rho.
    \label{appen:decom_grad}
\end{equation}
For the first part, we can use Chebyshev's inequality (\ref{appen:cheby}), giving
\begin{equation*}
    \left\|\cpzh \dfrac{\bar{r}(X\uz_i)}{\bar\rho\trans \bar{r}(X\uz_i)} -\EE_0 \dfrac{\bar{r}(X)}{\bar\rho\trans \bar{r}(X)}\right\|_2 \lessp \sqrt{\frac{1}{N_0}\cdot\EE_0 \frac{\bar{r}(X)\trans \bar{r}(X)}{(\bar{\rho}\trans \bar{r}(X))^2}}.
\label{appen:grad1}
\end{equation*}
Similarly, in Assumption \ref{assum:1} we have $\lambda_{\max}(\bar\Omega(\bar\rho)) \leqslant C_1$. Because $\lambda_{\max}(\cdot)$ is a continuous function, so when $n = N_0$ is sufficiently large,
\begin{equation*}
    \EE_0 \frac{\bar{r}(X)\trans \bar{r}(X)}{(\bar{\rho}\trans \bar{r}(X))^2} = \text{tr}(\bar\Omega(\bar{\rho})) \leqslant LC_1
\end{equation*}
Therefore, we obtain 
\begin{equation}
    \left\|\cpzh \dfrac{\bar{r}(X\uz_i)}{\bar\rho\trans \bar{r}(X\uz_i)} -\EE_0 \dfrac{\bar{r}(X)}{\bar\rho\trans \bar{r}(X)}\right\|_2 \lessp \sqrt{\frac{L}{N_0}}.
\label{appen:dis1}
\end{equation}
For the second part in (\ref{appen:decom_grad}), let $g(r) = \dfrac{r}{\rho\trans r}, r>0$ and $\rho \in \Delta_L$, we have
\begin{align*}
    \|g(r)-g(s)\|_2 = & \frac{\| r\rho\trans s - s\rho\trans r \|_2}{(\rho\trans r)(\rho\trans s)} = \frac{\| r\rho\trans (r+s-r) - (r+s-r)\rho\trans r \|_2}{(\rho\trans r)(\rho\trans s)} \\
    = & \frac{\| r\rho\trans (s-r) - (s-r)\rho\trans r \|_2}{(\rho\trans r)(\rho\trans s)} \leqslant \frac{2 \|r\|_2\|\rho\|_2\|r-s\|_2}{(\min_l r_l)(\min_l s_l)} \\
    \leqslant & \frac{2 \sqrt{L}\|r\|_{\infty} \|\rho\|_1\|r-s\|_2}{(\min_l r_l)(\min_l s_l)}
\end{align*}
Therefore, using $\|\bar\rho\|_1 = 1$ and Assumption \ref{assum:overlap}, we have
\begin{align}
    \left\| \cpzh \dfrac{\widehat{r}(X\uz_i)}{\bar\rho\trans\widehat{r}(X\uz_i)} - \cpzh \dfrac{\bar{r}(X\uz_i)}{\bar\rho\trans \bar{r}(X\uz_i)}  \right\|_2 &\leqslant \cpzh 2\sqrt{L} \frac{\| \bar{r}(X\uz_i)\|_\infty \|\widehat{r}(X\uz_i) - \bar{r}(X\uz_i)\|_2}{(\min_l \bar{r}_l(X\uz_i))(\min_l \widehat{r}_l(X\uz_i))} \notag \\
    & \leqslant 2\sqrt{L}C_w^3 \cpzh \|\widehat{r}(X\uz_i) - \bar{r}(X\uz_i)\|_2 \notag \\
    & \lessp \sqrt{L}C_w^3 \EE_0 \|\widehat{r}(X) - \bar{r}(X)\|_2 \notag \\
    &\lessp \sqrt{L}\Delta^r(N_{[L]}) \label{appen:dis2}
\end{align}
For the last part, according to the choice of tuning parameter, we have
\begin{equation}
    \|\lambda \bar\rho \|_2 \leqslant |\lambda| \|\bar{\rho}\|_1 \lesssim \frac{1}{\sqrt{N_0}} 
    \label{appen:eq:lambdarho}
\end{equation}
Combining (\ref{appen:dis0}), (\ref{appen:decom_grad}), (\ref{appen:dis1}), (\ref{appen:dis2}) and (\ref{appen:eq:lambdarho}), we get
\begin{equation*}
    \|\widehat{\rho} - \bar\rho \|_2 \lessp \sqrt{\frac{L}{N_0}} + \sqrt{L} \Delta^r(N_{[L]}). \label{appen:rhorate1}
\end{equation*}
We can also bound the $L_1$ norm as
\begin{equation}
    \|\widehat{\rho} - \bar\rho \|_1 \lessp \frac{L}{\sqrt{N_0}} + L \Delta^r(N_{[L]}). \label{appen:rhorate2}
\end{equation}

\subsubsection*{Part II: Convergence rate of $\widehat\eta$}
Because
\begin{align*}
    \elh - \elb & = \frac{\widehat{\rho}_l \widehat{r}_l}{\widehat{\rho}\trans \widehat{r}} - \frac{\bar{\rho}_l \bar{r}_l}{\bar{\rho}\trans\bar r} = \frac{\widehat{\rho}_l \widehat{r}_l \bar{\rho}\trans\bar r - \bar{\rho}_l \bar{r}_l \widehat{\rho}\trans \widehat{r}}{(\widehat{\rho}\trans \widehat{r})(\bar{\rho}\trans\bar r)} \\
    & = \frac{(\bar{\rho}_l + \widehat{\rho}_l - \bar\rho_l) (\bar{r}_l + \widehat{r}_l -\bar{r}_l) \bar{\rho}\trans\bar r - \bar{\rho}_l \bar{r}_l (\bar{\rho} + \widehat{\rho} - \bar\rho)\trans (\bar{r} + \widehat{r} -\bar{r})}{(\widehat{\rho}\trans \widehat{r})(\bar{\rho}\trans\bar r)}.
\end{align*}
Omitting high order terms involving $( \widehat{\rho}_l - \bar\rho_l) (\widehat{r}_l -\bar{r}_l)$, we have
\begin{align}
    |\elh(X\uz_i) - \elb(X\uz_i)| \lessp & \frac{|\widehat{\rho}_l - \bar\rho_l| \bar{r}_l(X\uz_i) \bar{\rho}\trans\bar r(X\uz_i) + \bar{\rho}_l |\widehat{r}_l(X\uz_i) -\bar{r}_l(X\uz_i)| \bar{\rho}\trans\bar r(X\uz_i)}{(\min_l \bar{r}_l(X\uz_i))(\min_l \widehat{r}_l(X\uz_i))} \notag \\
    & + \frac{\bar{\rho}_l \bar{r}_l(X\uz_i) \|\widehat{\rho} - \bar\rho\|_1  \|\bar{r}(X\uz_i)\|_\infty  + \bar{\rho}_l \bar{r}_l(X\uz_i) \|\bar{\rho}\|_1 \|\widehat{r}(X\uz_i) -\bar{r}(X\uz_i)\|_2}{(\min_l \bar{r}_l(X\uz_i))(\min_l \widehat{r}_l(X\uz_i))} \notag \\
    \lessp & C_w^4 |\widehat{\rho}_l - \bar\rho_l| + C_w^3 |\widehat{r}_l(X\uz_i) -\bar{r}_l(X\uz_i)| + C_w^4 \bar\rho_l \|\widehat{\rho}-\bar\rho\|_1 + C_w^3 \bar\rho_l \|\widehat{r}(X\uz_i) -\bar{r}(X\uz_i)\|_2 \notag \\
    \lessp &   \|\widehat{\rho} - \bar\rho\|_1 +   \|\widehat{r}(X\uz_i) -\bar{r}(X\uz_i)\|_2 \label{appen:eq:etahatl}
\end{align}
Therefore, for any $l\in[L]$, using conclusion from (\ref{appen:rhorate2}), we have
\begin{align*}
    \| \elh - \elb \|_{2,0}^2 & = \EE_0 |\elh(X\uz_i) - \elb(X\uz_i)|^2 \\
    & \lessp ( \|\widehat{\rho} - \bar\rho\|_1 +   \EE_0 \|\widehat{r}(X) -\bar{r}(X)\|_2)^2\\
    & \lesssim   \|\widehat{\rho} - \bar{\rho}\|_1^2 +  \EE_0 \|\widehat{r}(X) -\bar{r}(X)\|_2^2 \\
    & \lessp \frac{ L^2}{N_0} +  L^2 \EE_0 \|\widehat{r}(X) -\bar{r}(X)\|_2^2
\end{align*}
Therefore, we can get
\begin{equation*}
    \| \elh - \elb \|_{2,0} \lessp \frac{L  }{\sqrt{N_0}} + L   \Delta^r(N_{[L]})
\end{equation*}
For $\| \elh - \elb \|_{2,l}$, the argument is almost the same. Because the estimation of $\widehat{\rho}$ always depends on the data on the target site, so we only need to replace the $X\uz_i$ in (\ref{appen:eq:etahatl}) with $X\ul_j$, using rate of $\EE_l \|\widehat{r}(X) -\bar{r}(X)\|_2$ from Assumption \ref{assum:rate} to arrive at the same conclusion. \qed

% \begin{lemma}
%     The difference of $\widehat{\rho}$ and $\widetilde{\rho}$ follows the rate of $\widehat{r}_l$:
%     \begin{equation}
%         \widehat{\rho} - \widetilde{\rho} = C \Delta^r(N_{\min})
%     \end{equation}
%     where $N_{\min}$ is the smallest covariate source sample size.
% \end{lemma}




\subsection{Proof of Lemma \ref{lemma:Rrate} }
\textbf{Proof.} 
We first state the Cauchy inequality for the $L_2$-norm.
\begin{lemma}(Cauchy Inequality for $L_2$-norm) Let $b_i$ be real numbers and $A_i$ be vectors in $\mathbb{R}^q$, $i = 1,2,\cdots,N$, and $\cpzh = \frac{1}{N}\sum_{i=1}^N$ is the sample mean operator. Then
\begin{equation}
    \|\cpzh b_iA_i\|_2 \leqslant (\cpzh b_i^2)^{\frac{1}{2}} (\cpzh \|A_i\|_2^2)^{\frac{1}{2}}.
    \label{eq:cauchy}
\end{equation}
\end{lemma}

\noindent \textbf{Proof.} Let $A_i = (A_{i1},\cdots,A_{iq})$, then using Cauchy inequality for scalar:
\begin{equation*}
    (\cpzh b_ia_i)^2 \leqslant (\cpzh b_i^2) (\cpzh a_i^2),
\end{equation*}
we have
\begin{align*}
    \|\cpzh b_iA_i\|_2^2 = & \sumq (\cpzh b_iA_{ik})^2 \leqslant \sumq (\cpzh b_i^2)(\cpzh A_{ik}^2)\\
    = & (\cpzh b_i^2)  (\cpzh \sumq A_{ik}^2) = (\cpzh b_i^2)  (\cpzh \|A_{i}\|_2^2) 
\end{align*}
\qed

\subsubsection*{Part I: Convergence of $\qlh$}
We firstly focus on $l \in [L]$. We decompose $\qlh$ and $\bar{\beta}_l$ into two parts. Define
\begin{align}
    \rlh &= \cpzh \mlh(X_i\uz) A_i\uz + \cplh \wlh(X^{(l)}_j) [Y^{(l)}_j-\mlh(X^{(l)}_j)] A\ul_j \label{appen:eq:rlh} \\
    \bar{R}_l &= \EE_0 \bar {m}_l(X_i\uz) A_i\uz \label{appen:eq:rlb}
\end{align}
Then we can see that $\blh = (\szh)\inv \rlh; \blb = (\szh)\inv \rlb$.
Therefore,
\begin{align}
    \|\blh - \blb\|_2 = & \| (\szh)\inv \rlh - (\szh)\inv \rlb + (\szh)\inv \rlb - (\bar\Sigma\uz)\inv \rlb \|_2 \notag \\
    \leqslant & \| (\szh)\inv \|_2 \| \rlh - \rlb \|_2 + \|\rlb \|_2 \| (\szh)\inv - (\bar\Sigma\uz)\inv\|_2 \label{appen:eq:betahat}
\end{align}

First we bound $\| \rlh - \rlb \|_2$. We know that $Y\ul_j = \bar m_l(X\ul_j) + \varepsilon\ul_j$; and from the definition of density ratio and independence created by the sample splitting, we have $\EE_0 (\mlh(X\uz_i) - \bar m_l(X\uz_i))A\uz_i = \EE_l w_l(X\ul_j)(\mlh(X\ul_j) - \bar m_l(X\ul_j))A\ul_j$. We plug these two terms in the expression and $\rlh - \rlb$ can be decomposed as:
\begin{align*}
    \begin{split}
    \rlh - \rlb = & \cpzh \mlh(X\uz_i) A\uz_i + \cplh \wlh(X\ul_j) (Y\ul_j - \mlh(X\ul_j)) A\ul_j - \EE_0 \bar{m}_l(X\uz)A\uz \\
    = & \left(\cpzh \bar m_l(X\uz_i) A\uz_i - \EE_0 \bar m_l(X\uz)A\uz \right) +  \\
    & \left( \cpzh (\mlh(X\uz_i) - \bar m_l(X\uz_i)) A\uz_i - \EE_0 (\mlh(X\uz) - \bar m_l(X\uz))A\uz \right) - \\
    & \left( \cplh \bar w_l(X\ul_j) (\mlh(X\ul_j) - \bar m_l(X\ul_j)) A\ul_j - \EE_l \bar w_l(X\ul_j)(\mlh(X\ul_j) - \bar m_l(X\ul_j))A\ul_j \right) + \\
    & \left(\cplh \wlh(X\ul_j) \varepsilon\ul_j A\ul_j \right) - \left( \cplh (\wlh(X\ul_j) - \bar w_l(X\ul_j)) (\mlh(X\ul_j) - \bar m_l(X\ul_j)) A\ul_j \right) \\
    =: &  \Delta_{11} + \Delta_{12} + \Delta_{13} + \Delta_{14} + \Delta_{15}
    \end{split}
\end{align*}
We can bound these terms separately as follows. Then using Chebyshev inequality (\ref{appen:cheby}):
\begin{equation}
    \| \Delta_{11} \|_2 \lessp \sqrt{\frac{\EE_0 \| \bar{m}_l(X\uz_i)A\uz\|_2^2}{N_0}} = \frac{\|\bar{m}_l\|_{A,0}}{\sqrt{N_0}} \lessp \frac{1}{\sqrt{N_0}}.
    \label{appen:delta11}
\end{equation}
For $\Delta_{12}$, using the norm we defined in Section \ref{sec:theory}, we have 
\begin{equation}
    \| \Delta_{12} \|_2 \lessp \frac{\| \mlh - \mlb\|_{A,0}}{\sqrt{N_0}} \lessp \frac{\Delta^m(n_l)}{\sqrt{N_0}}.
    \label{appen:delta12}
\end{equation}
For $\Delta_{13}$, using Assumption \ref{assum:overlap} we have
\begin{equation}
    \| \Delta_{13} \|_2 \lessp \frac{\| \wlb(\mlh - \mlb)\|_{A,l}}{\sqrt{n_l}} \leqslant \frac{C_w\|\mlh - \mlb\|_{A,l}}{\sqrt{n_l}} \lessp \frac{C_w\Delta^m(n_l)}{\sqrt{n_l}}.
    \label{appen:delta13}
\end{equation}
For the term $\Delta_{14}$, because $\varepsilon\ul_j$ is mean-zero and independent of $X\ul_j$, by using $\|\wlh \|_{A,l}\leqslant \|\wlb \|_{A,l} + \|\wlh - \wlb \|_{A,l}$ we get:
\begin{equation}
    \| \Delta_{14} \|_2 \lessp \sqrt{\frac{\EE_l \| \wlh(X\ul)\varepsilon\ul A\ul\|_2^2}{N_0}} \leqslant \frac{\sigma^2_{\varepsilon}\|\wlh \|_{A,l}}{\sqrt{n_l}} \lessp \frac{1+\Delta^w(N_0\wedge N_l)}{\sqrt{n_l}}.
    \label{appen:delta14}
\end{equation}
For $\Delta_{15}$, this term is not mean zero, we use Cauchy's inequality in (\ref{eq:cauchy}) and apply Markov's inequality to each term:
\begin{align}
    \| \Delta_{15} \|_2 \leqslant & \sqrt{\cplh (\wlh(X\ul_j)-\wlb(X\ul_j))^2} \sqrt{\cplh \| (\mlh(X\ul_j)-\mlb(X\ul_j) A\ul_j\|_2^2} \notag \\
    \lessp & \|\wlh - \wlb\|_{2,l} \|\mlh-\mlb\|_{A,l} \lessp {\Delta^w(N_0\wedge N_l)\Delta^m(n_l)}. \label{appen:delta15}
\end{align}
Combining bounds (\ref{appen:delta11}),(\ref{appen:delta12}),(\ref{appen:delta13}),(\ref{appen:delta14}),(\ref{appen:delta15}), and omitting the higher order term in (\ref{appen:delta12}),(\ref{appen:delta13}) and (\ref{appen:delta14}), we have
\begin{equation*}
\| \widehat{R}_l - \rlb \|_2 \lesssim_{\sf P} \sqrt{\frac{1}{N_0\wedge n_l}} + \Delta^m (n_l)\Delta^{w}(N_0\wedge N_l),\quad l\in [L].  
\end{equation*}
For $\| (\szh)\inv - (\bar\Sigma\uz)\inv\|_2$, first we have
\begin{equation*}
    \| (\szh)\inv - (\bar\Sigma\uz)\inv\|_2 = \| (\szh)\inv \|_2 \cdot \|(\bar\Sigma\uz)\inv \|_2 \cdot \| \szh- \bar\Sigma\uz\|_2.
\end{equation*}
Each element in $\szh$ is an average, therefore from central limit theorem we have
\begin{equation*}
    \sqrt{N_0} \operatorname{vec}\left(\szh-\bar\Sigma\uz \right) \xrightarrow{d} N(0, V),
\end{equation*}
where $\operatorname{vec}(\cdot)$ is the vectorization operator that stacks the columns of a matrix into a single vector. Because the Euclidean norm of $\operatorname{vec}\left(\szh-\bar\Sigma\uz\right)$ is equivalent to the Frobenius norm of $\szh-\bar\Sigma\uz$
$$
\left\|\szh-\bar\Sigma\uz\right\|_F=\left\|\operatorname{vec}\left(\szh-\bar\Sigma\uz\right)\right\|_2,
$$
and the operator norm is bounded above by the Frobenius norm:
$$
\left\|\szh-\bar\Sigma\uz\right\|_2 \leqslant\left\|\szh-\bar\Sigma\uz\right\|_F.
$$
Therefore, $\left\|\szh-\bar\Sigma\uz\right\|_2 \lessp \dfrac{1}{\sqrt{N_0}}$. From Weyl's inequality we have $$\lambda_{\min}(\szh) \geqslant \lambda_{\min} (\bar\Sigma\uz) - \left\|\szh-\bar\Sigma\uz\right\|_2,$$ so when $N_0$ is sufficiently large such that $\left\|\szh-\bar\Sigma\uz\right\|_2 \leqslant \frac{1}{2}C_1\inv$, we have
\begin{equation}
    \| (\szh)\inv \|_2 = \frac{1}{\lambda_{\min}(\szh)} \leqslant \frac{1}{\lambda_{\min} (\bar\Sigma\uz) - \left\|\szh-\bar\Sigma\uz\right\|_2} \leqslant 2C_1.
    \label{appen:eq:szhbound}
\end{equation} 
So we get 
\begin{equation}
    \| (\szh)\inv - (\bar\Sigma\uz)\inv\|_2 = \| (\szh)\inv \|_2 \cdot \|(\bar\Sigma\uz)\inv \|_2 \cdot \| \szh- \bar\Sigma\uz\|_2 \lessp \frac{1}{\sqrt{N_0}}. \label{appen:eq:szhrate}
\end{equation}
For $\|\bar{R}_l\|_2$, we know that
\begin{equation*}
    \|\bar{R}_l\|_2 = \| \EE_0 \bar{m}_l(X\uz)A\uz \|_2 \leqslant \EE_0 \| \bar{m}_l(X\uz)A\uz \|_2 = \|\bar{m}_l\|_{A,0} \leqslant C_2.
\end{equation*}
Plugging back to (\ref{appen:eq:betahat}) we have
\begin{equation}
    \|\blh - \blb\|_2 \lessp \sqrt{\frac{1}{N_0\wedge n_l}} + \Delta^m (n_l)\Delta^{w}(N_0\wedge N_l),\quad l \in [L].
\label{appen:errl}
\end{equation}

\subsubsection*{Part II: Convergence of $\ph$}
Then we turn to the convergence of $\ph$. We also decompose $\ph$ and $\bar{\beta}_{L+1}$ into two parts. Define
\begin{align*}
    \widehat{R}_{L+1} &=  \suml \cpzh \elh(X_i\uz) \mlh(X_i\uz) A_i\uz + \cplh \elh(X_j\ul)\wlh(X^{(l)}_j) [Y^{(l)}_j-\mlh(X^{(l)}_j)] A\ul_j  \\
    \bar{R}_{L+1} &= \suml \EE_0 \elb(X_i\uz) \bar {m}_l(X_i\uz) A_i\uz 
\end{align*}
Then we can see that $\widehat{\beta}_{L+1} = (\szh)\inv \widehat{R}_{L+1}; \bar{\beta}_{L+1} = (\szh)\inv \bar{R}_{L+1}$. Similar to the convergence of $\blh$ in (\ref{appen:eq:betahat}), we also have
\begin{align}
    \|\ph - \bar{\beta}_{L+1}\|_2 = & \| (\szh)\inv \widehat{R}_{L+1} - (\szh)\inv \bar{R}_{L+1} + (\szh)\inv \bar{R}_{L+1} - (\bar\Sigma\uz)\inv \bar{R}_{L+1} \|_2 \notag \\
    \leqslant & \| (\szh)\inv \|_2 \| \ph - \bar{\beta}_{L+1} \|_2 + \|\bar{R}_{L+1} \|_2 \| (\szh)\inv - (\bar\Sigma\uz)\inv\|_2 \label{appen:eq:betamixhat}
\end{align}
$\rlpwh - R_{L+1}$ can be decomposed as
\begin{align*}
    \begin{split}
        \rlpwh - \bar R_{L+1} = & \suml \bigg\{ \cpzh \elh(X\uz_i) \mlh(X\uz_i) A\uz_i + \cplh \elh(X\ul_j) \wlh(X\ul_j) (Y\ul_j - \mlh(X\ul_j)) A\ul_j  \\
        & - \EE_0 \bar\eta_l(X\uz) \bar m_l(X\uz)A\uz \bigg\}\\
        = & \suml \bigg\{ \left(\cpzh \bar\eta_l(X\uz_i) \bar m_l(X\uz_i) A\uz_i - \EE_0 \bar\eta_l(X\uz) \bar m_l(X\uz)A\uz \right) +  \\
        & \left(\cpzh (\elh(X\uz_i) - \bar \eta_l(X\uz_i)) \bar m_l(X\uz_i) A\uz_i\right) + \\
        & \left(\cpzh \elh (X\uz_i)( \mlh(X\uz_i) -\bar m_l(X\uz_i) ) A\uz_i - \EE_0 \elh (X\uz)( \mlh(X\uz) -\bar m_l(X\uz)) A\uz \right) - \\
        & \left( \cplh \elh (X\ul_j) \bar w_l(X\ul_j) (\mlh(X\ul_j) - \bar m_l(X\ul_j) ) A\ul_j  - \EE_0 \elh (X\uz) (\mlh(X\uz) - \bar m_l(X\uz) ) A\uz  \right) + \\
        & \left( \cplh \elh (X\ul_j) \wlh(X\ul_j) \varepsilon_j\ul A\ul_j\right) - \\
        & \left( \cplh \elh (X\ul_j)( \mlh(X\ul_j) -\bar m_l(X\ul_j)) (\wlh(X\ul_j) - \bar w_l(X\ul_j)) A\ul_j \right) \bigg\}\\
         =: & \suml (\Delta_{21l}+\Delta_{22l}+\Delta_{23l}+\Delta_{24l}+\Delta_{25l}+\Delta_{26l})
    \end{split}
\end{align*}
From the Assumption \ref{assum:overlap}, we know that
\begin{equation}
    \bar{\eta}_l(x) = \frac{\bar\rho_l/\bar{w}_l(x)}{\sum_{k=1}^L \bar{\rho}_k / \bar{w}_k(x)} \leqslant C_w^2 \frac{\bar\rho_l}{\sum_{k=1}^L \bar{\rho}_k } = C_w^2\bar{\rho}_l, \quad \forall l \in [L].
\label{eq:etabound}
\end{equation}
For term $\Delta_{21l}$, using (\ref{eq:etabound}) and (\ref{appen:delta11}) we have
\begin{equation}
    \|\Delta_{21l}\|_2 \leqslant C_w^2 \bar{\rho}_l \left(\cpzh \bar m_l(X\uz_i) A\uz_i - \EE_0 \bar m_l(X\uz)A\uz \right) \lessp   \bar{\rho}_l \sqrt{\frac{1}{N_0}}
    \label{appen:delta21}
\end{equation}
For term $\Delta_{22l}$, we use Cauchy's inequality and Markov's inequality:
\begin{align}
    \| \Delta_{22l} \|_2 \lessp & \sqrt{\cpzh (\elh(X\uz_i) - \bar \eta_l(X\uz_i))^2} \sqrt{\cpzh \| \mlb(X\uz_i) A\uz_i\|^2_2} \notag \\
    \lessp & \|\elh - \elb \|_{2,0} \|\mlb\|_{A,0} \lessp \Delta^{\eta} (N_0,N_{[L]}).
    \label{appen:delta22}
\end{align}
Because $\elh \to \bar{\eta}_l$ when sample sizes go to infinity, we can also bound $\elh(x) \lesssim C_w^2\bar{\rho}_l$ for $l \in [L]$. Using Chebyshev's inequality for term $\Delta_{23l}$ and combine (\ref{appen:delta12}) we will get
\begin{equation}
    \| \Delta_{23l} \|_2 \lessp C_w^2 \bar\rho_l \frac{\| \mlh - \mlb\|_{A,0}}{\sqrt{N_0}} \lessp   \bar\rho_l \frac{\Delta^m(n_l)}{\sqrt{N_0}}.
    \label{appen:delta23}
\end{equation}
Similar to (\ref{appen:delta13}) we have
\begin{equation}
    \| \Delta_{24l} \|_2 \lessp C_w^2 \bar\rho_l\frac{\| \wlb(\mlh - \mlb)\|_{A,l}}{\sqrt{n_l}} \lessp   \bar\rho_l\frac{\Delta^m(n_l)}{\sqrt{n_l}}.
    \label{appen:delta24}
\end{equation}
because $\varepsilon\ul_j$ is mean-zero, from (\ref{appen:delta14}) we get:
\begin{equation}
    \| \Delta_{25l} \|_2 \lessp C_w^2 \bar\rho_l \sigma_{\varepsilon}^2 \frac{\|\wlh \|_{A,l}}{\sqrt{n_l}} \lessp   \bar\rho_l \frac{1+\Delta^w(N_0\wedge N_l)}{\sqrt{n_l}}.
    \label{appen:delta25}
\end{equation}
Using Markov's inequality and from (\ref{appen:delta15}),
\begin{equation}
    \| \Delta_{26l} \|_2 \lessp C_w^2 \bar\rho_l \| \wlh-\wlb \|_{2,l} \|\mlh - \mlb\|_{A,l} \lessp  \bar\rho_l {\Delta^w(N_0\wedge N_l)\Delta^m(n_l)}.
    \label{appen:delta26}
\end{equation}
Combining bounds in (\ref{appen:delta21}),(\ref{appen:delta22}),(\ref{appen:delta23}),(\ref{appen:delta24}),(\ref{appen:delta25}) and (\ref{appen:delta26}) we know that
\begin{equation*}
    \| \rlpwh - \bar R_{L+1} \|_2 \lessp \sum_{l=1}^L  \bar\rho_l \Big(\sqrt{\frac{1}{N_0\wedge n_l}} + \Delta^{m} (n_l)\Delta^{w}(N_0\wedge N_l)\Big) +\Delta^{\eta}(N_0,N_{[L]})
\end{equation*}
Therefore, back to (\ref{appen:eq:betamixhat}) and using the same argument in (\ref{appen:errl}) we can get
\begin{equation*}
    \|\ph - \bar{\beta}_{L+1}\|_2 \lessp \sum_{l=1}^L   \bar\rho_l \Big(\sqrt{\frac{1}{N_0\wedge n_l}} + \Delta^{m} (n_l)\Delta^{w}(N_0\wedge N_l)\Big) +\Delta^{\eta}(N_0,N_{[L]}).
\end{equation*}
\qed 
\subsection{Proof of Theorem \ref{thm:betarate}}
\textbf{Proof.} 
We know that
\begin{align*}
    \begin{split}
     \| \ours(\smax) - \barbetare(\smax) \|_2 = & \| \sumll \left( \glh \blh - \gamma_l^* \bar{\beta}_l \right) \|_2 \\
     \leqslant & \sumll \glh \|\qlh - \blb \|_2 + \sumll |\glh - \gamma_l^*| \|\blb \|_2 \\
     \leqslant & (\sumll \glh) \max_{l\in[L+1]} \|\qlh - \blb \|_2 + \|\widehat{\gamma} - \gamma^*\|_2 \sqrt{\sumll\|\blb \|^2_2} \\
     = & \max_{l\in[L+1]} \|\qlh - \blb \|_2 + \|\widehat{\gamma} - \gamma^*\|_2 \sqrt{\sumll\|\blb \|^2_2}
    \end{split}
\end{align*}

\begin{lemma}
    $\widehat{\gamma}$ solves $\min\limits_{\gamma \in \mathcal{M}} \gamma\trans \widehat{\Gamma} \gamma,$ $\gamma^*$ solves $\min\limits_{\gamma \in \mathcal{M}} \gamma\trans \Gamma \gamma,$ then if $\lambda_{\min}(\Gamma)>0$, then
\begin{equation*}
\left\|\widehat{\gamma}-\gamma^*\right\|_2 \leqslant \frac{\|\widehat{\Gamma}-\Gamma\|_2}{\lambda_{\min }(\Gamma)} \wedge \rho_{\mathcal{M}}.
\end{equation*}
\label{lemma:gammarate}
\end{lemma}
\noindent \textbf{Proof.} The proof of this lemma follows the claim we made in Lemma \ref{lemma:eta}. We set $L(\gamma) = \gamma\trans \Gamma \gamma$ and $L_n(\gamma) = \gamma\trans \widehat{\Gamma}\gamma$. Following (\ref{appen:1order1}), (\ref{appen:1order2}) and (\ref{appen:rrr}), using the quadratic form of loss function, $\nabla L(\gamma) = 2\Gamma\gamma$, we have
\begin{align}
     \nabla L(\widehat\gamma) \trans (\widehat{\gamma}-\gamma^*) \geqslant & (\nabla L(\widehat\gamma) - \nabla L(\gamma^*))\trans (\widehat{\gamma}-\gamma^*) \notag \\
    = &\ 2(\widehat{\gamma}-\gamma^*)\trans\Gamma (\widehat{\gamma}-\gamma^*) \label{appen:rrrgamma}
\end{align}
Following (\ref{appen:lll}), combining result in (\ref{appen:rrrgamma}) we have
\begin{align}
        \lambda_{\min}(\Gamma) \|\widehat{\gamma}-\gamma^*\|_2^2 \leqslant & (\widehat{\gamma}-\gamma^*)\trans\Gamma (\widehat{\gamma}-\gamma^*) \leqslant  \widehat{\gamma}\trans (\Gamma - \widehat{\Gamma}) (\widehat{\gamma}-\gamma^*) \notag \\
         \leqslant & \|\widehat{\gamma}\|_2 \|\widehat{\Gamma} - \Gamma\|_2 \|\widehat{\gamma}-\gamma^*\|_2 \label{appen:eq:gammahat}
\end{align}
Using the fact that $\|\widehat{\gamma}\|_2 \leqslant \|\widehat{\gamma}\|_1 = 1$ in (\ref{appen:eq:gammahat}) and we can get the desired conclusion in Lemma \ref{lemma:gammarate}. \qed

Since $\| \widehat{\Gamma} - \Gamma \|_2 \leqslant (L+1) \max\limits_{l,k \in [L+1]} |\widehat{\Gamma}_{l,k} - \Gamma_{l,k}|$, using the notation we define in (\ref{appen:eq:rlh}) and (\ref{appen:eq:rlb}), we decompose the component-wise convergence as follows:
\begin{align*}
     |\widehat{\Gamma}_{l,k} - \Gamma_{l,k}| = & |(\rlh)\trans (\szh)\inv \widehat{R}_k - \bar R_k\trans (\bar\Sigma\uz)\inv \bar R_l | \\
     \leqslant & \big| \bar R_l\trans ((\szh)\inv - (\bar\Sigma\uz)\inv) \bar R_k \big| + \big| (\widehat{R}_k - \bar R_k)\trans (\szh)\inv \bar R_l \big| \\
     & + \big| \bar R_k\trans (\szh)\inv (\rlh - \bar R_l) \big| + \big|(\widehat{R}_k - \bar R_k) \trans (\szh)\inv (\rlh - \bar R_l)\big| \\
     \leqslant & \|\rlb\|_2 \|\bar R_k\|_2 \|(\szh)\inv - (\bar\Sigma\uz)\inv\|_2 + \|(\szh)\inv\|_2 \|\rlb\|_2 \|\widehat{R}_k - \bar R_k\|_2 \\
     & + \|(\szh)\inv\|_2 \|\bar R_k\|_2 \|\widehat{R}_l - \bar R_l\|_2 + \|(\szh)\inv\|_2 \|\widehat{R}_l - \bar R_l\|_2 \|\widehat{R}_k - \bar R_k\|_2
\end{align*}
Using the conclusion from (\ref{appen:eq:szhbound}), (\ref{appen:eq:szhrate}) and Lemma \ref{lemma:Rrate}, we have
\begin{equation*}
    |\widehat{\Gamma}_{l,k} - \Gamma_{l,k}| \lessp \frac{1}{\sqrt{N_0}} + \text{Err}_l + \text{Err}_k + \text{Err}_l \cdot \text{Err}_k
\end{equation*}
Therefore,
\begin{equation*}
    \| \widehat{\Gamma} - \Gamma \|_2 \lessp L \max_{l \in [L+1]} \text{Err}_l
\end{equation*}
Using Lemma \ref{lemma:gammarate}, because we solve the quadratic optimization problem in the set $\mathcal{S}(\smax)$, substituting back we can get
\begin{align*}
    \| \ours(\smax) - \barbetare(\smax) \|_2 \lessp & \max_{l\in[L+1]} \|\qlh - \blb \|_2 + \|\widehat{\gamma} - \gamma^*\|_2 \sqrt{\sumll\|\blb \|^2_2} \\
    \leqslant & \max_{l \in [L+1]} \text{Err}_l + \sqrt{L}C_2 \left( \frac{\|\widehat{\Gamma}-\Gamma\|_2}{\lambda_{\min }(\Gamma)} \wedge d(\mathcal{S}(\smax)) \right) \\
    \lessp & \max_{l \in [L+1]} \text{Err}_l +   \frac{L^{3/2}\|\widehat{\Gamma}-\Gamma\|_2}{\lambda_{\min }(\Gamma)} \wedge \sqrt{L}d(\mathcal{S}(\smax)). 
\end{align*}
\qed

\subsection{Proof of Theorem \ref{thm:truerate}}
\textbf{Proof.} 
We define the population loss function as 
\begin{equation*}
    L(\beta) = \EE_0 (Y-A\trans \beta)^2
\end{equation*}
and the empirical loss function which is built on the labeled samples for tuning as
\begin{equation*}
    L_n(\beta) = \frac{1}{n_\dagger} \sum_{i=1}^{n_\dagger} \big(Y^\dagger_i-\beta\trans A^\dagger_i\big)^2.
\end{equation*}
Therefore we know that
\begin{equation*}
    \beta^*=\underset{\beta \in \mathbb{R}^q}{\arg\min}\ \EE_{\mathbb{P}^{(0)}}\left(Y-A\trans \beta\right)^2 = \underset{\beta \in \mathbb{R}^q}{\arg\min}\ L(\beta)
\end{equation*}
and we denote the direct OLS estimator as 
\begin{equation*}
    \betaols = \underset{\beta \in \mathbb{R}^q}{\arg\min}\ \frac{1}{n_\dagger} \sum_{i=1}^{n_\dagger} \big(Y^\dagger_i-\beta\trans A^\dagger_i\big)^2 = \underset{\beta \in \mathbb{R}^q}{\arg\min}\ L_n(\beta).
\end{equation*}
We denote $\widehat{\mathcal{P}}_\dagger= n_\dagger\inv \sum_{i=1}^{n_\dagger}$ as the empirical mean operator for tuning labeled samples, and $\widehat{\Sigma}^\dagger = \widehat{\mathcal{P}}_\dagger A_i^\dagger (A_i^\dagger)\trans$ as the empirical covariance matrix for $X^\dagger_i$. By the tuning procedure we have
\begin{equation*}
    \widehat{\smax} = \underset{\smax\in\Csc}{\arg\min}\ L_n(\ours(\smax)).
\end{equation*}
Therefore, by definition we have 
\begin{equation}
    L_n(\ours(\widehat\smax)) \leqslant L_n(\ours(0)). 
\label{eq:thm3-1}
\end{equation}
Notice that the gradient of $L_n$ at minimizer $\betaols$ is 0, so we have
\begin{equation*}
    L_n(\beta) - L_n(\betaols) = \frac{1}{2}(\beta-\betaols)\trans \nabla^2L_n(\betaols) (\beta-\betaols)
\end{equation*}
where $\nabla^2L_n(\betaols) = 2\widehat{\Sigma}^\dagger$. By subtracting $L_n(\betaols)$ on both sides of (\ref{eq:thm3-1}), we can get
\begin{equation*}
    \| \ours(\widehat\smax) - \betaols\|_2 \leqslant C_1 \|\ours(0)-\betaols \|_2
\end{equation*}
Therefore by triangular inequality 
\begin{align}
    \| \ours(\widehat\smax) - \beta^*\|_2 \leqslant & \| \ours(\widehat\smax) -  \betaols \|_2 + \| \betaols - \beta^*\|_2 \notag \\
    \leqslant &\ C_1\|\ours(0)-\betaols \|_2 + \| \betaols - \beta^*\|_2 \notag \\
    \lesssim &\ \|\ours(0) - \beta^* \|_2 + \|\betaols - \beta^*\|_2 \label{eq:triagular}.
\end{align}
By setting $\smax = 0$, we have $\ours(0) = \ph$. For OLS estimator, we have
\begin{equation}
    \betaols = (\widehat\Sigma^\dagger)\inv \widehat{\mathcal{P}}_\dagger A^\dagger_i Y^\dagger_i.
    \label{eq:thm3-3}
\end{equation}
Given that labeled samples follow the contamination model (\ref{eq:contam1}),
\begin{equation}
    Y^\dagger_i = (1-s^*) \suml \bar\eta_l(X^\dagger_i)\bar{m}_l(X^\dagger_i) + s^* \bar m^{(\dagger,\varepsilon)}(X_i\uz) + \varepsilon^\dagger_i
    \label{eq:thm3-4}
\end{equation}
where $\bar m^{(\dagger,\varepsilon)}$ is the conditional expectation model under contamination part $\PP^{(\varepsilon)}_{Y|X}$ for the tuning labeled samples, and $\varepsilon_i^\dagger$ is the residual, $\EE(\varepsilon^\dagger_i \mid X^\dagger_i) = 0$. Therefore, by substituting (\ref{eq:thm3-4}) back into (\ref{eq:thm3-3}), we have
\begin{align}
    \betaols = &(1-s^*) \left[(\widehat\Sigma^\dagger)\inv \suml \widehat{\mathcal{P}}_\dagger \bar\eta_l(X^\dagger_i)\bar{m}_l(X^\dagger_i) A^\dagger_i \right] \notag \\
    & + s^* (\widehat\Sigma^\dagger)\inv \widehat{\mathcal{P}}_\dagger \bar{m}^{(\dagger,\varepsilon)}(X^\dagger_i) A^\dagger_i + (\widehat\Sigma^\dagger)\inv \widehat{\mathcal{P}}_\dagger A^\dagger_i \varepsilon^\dagger_i. \label{eq:thm3-ols} 
\end{align}
For population loss minimizer $\beta^*$, similarly we have
\begin{align}
    \beta^* = &(1-s^*) \left[(\bar\Sigma\uz)\inv \suml \EE_0 \bar\eta_l(X)\bar{m}_l(X) A \right] + s^* (\bar\Sigma\uz)\inv \EE_0 \bar{m}^{(\varepsilon)}(X) A \notag \\
    := & (1-s^*) \bar{\beta}_{L+1} + s^* \bar{\beta}^{(\varepsilon)} \label{eq:thm3-betastar}
\end{align}
where we use the notation from (\ref{eq:betabar}) for the first term and denote the second term as $\bar{\beta}^{(\varepsilon)}$. From the assumption that $\|\bar{m}^{(\varepsilon)}\|_{A,0} < C_3$, we know $\| \bar{\beta}^{(\varepsilon)} \|$ is bounded by a constant. And we should note that because both true target distribution $\PP\uz$ and the tuning samples distribution $\PP^\dagger$ both in the contamination family (\ref{eq:contam1}), their $X$ distributions are identical, only with different $\PP^{(\varepsilon)}_{Y|X}$, for which we use $\bar{m}^{(\varepsilon)}$ and $\bar{m}^{(\dagger,\varepsilon)}$ to denote them respectively. For the first part in (\ref{eq:triagular}), because $s^* \to 0$, we have 
\begin{align}
    \| \ours(0) - \beta^* \|_2 = &\ \| \ph - \bar{\beta}_{L+1} + s^* \bar{\beta}_{L+1} - s^* \bar{\beta}^{(\varepsilon)} \|_2 \notag \\
    \lesssim &\ \text{Err}_{\mix} + s^* \label{appen:eq:re0rate}
\end{align}
using Lemma \ref{lemma:Rrate} and boundedness of $\bar{\beta}^{(\varepsilon)}$ and $\ph$. The second part in (\ref{eq:triagular}) is the convergence of a ordinary least square estimator. Combining (\ref{eq:thm3-ols}) and (\ref{eq:thm3-betastar}) we have
\begin{align*}
   \|\betaols - \beta^*\|_2 \lesssim &\ s^* + \| (\widehat\Sigma^\dagger)\inv \widehat{\mathcal{P}}_\dagger A^\dagger_i \varepsilon^\dagger_i \|_2 \\
   & + \left\| \left[(\widehat\Sigma^\dagger)\inv \suml \widehat{\mathcal{P}}_\dagger \bar\eta_l(X^\dagger_i)\bar{m}_l(X^\dagger_i) A^\dagger_i \right] - \left[(\bar\Sigma\uz)\inv \suml \EE_0 \bar\eta_l(X)\bar{m}_l(X) A \right] \right\|_2 \\
   =: & s^* +\Delta_{31} + \Delta_{32}.
\end{align*}
For term $\Delta_{31}$, because $\varepsilon^\dagger_i$ are mean zero, using Chebyshev's inequality we can directly have $\|\Delta_{31}\|_2 \lessp \frac{1}{\sqrt{n_\dagger}}.$ For term $\Delta_{32}$, we conduct a decomposition
\begin{align*}
    \Delta_{32} \leqslant & \| (\widehat\Sigma^\dagger)\inv \|_2 \left\| \suml ( \widehat{\mathcal{P}}_\dagger \bar\eta_l(X^\dagger_i)\bar{m}_l(X^\dagger_i) A^\dagger_i - \EE_0 \bar\eta_l(X)\bar{m}_l(X) A) \right\|_2 \\
    & + \| \suml \EE_0 \bar\eta_l(X)\bar{m}_l(X) A \|_2 \| (\widehat\Sigma^\dagger)\inv - (\bar\Sigma\uz)\inv \|_2 
\end{align*}
The second term is bounded by $\frac{1}{\sqrt{N_0}}$ by the result in (\ref{appen:eq:szhrate}). In the first term, $\|(\widehat\Sigma^\dagger)\inv\|_2$ is bounded by (\ref{appen:eq:szhbound}), and using Chebyshev's inequality we have
\begin{align*}
 \left\| \suml ( \widehat{\mathcal{P}}_\dagger \bar\eta_l(X^\dagger_i)\bar{m}_l(X^\dagger_i) A^\dagger_i - \EE_0 \bar\eta_l(X)\bar{m}_l(X) A) \right\|_2 \lessp  C_w^2 \frac{\|\bar{m}_l\|_{A,0}}{\sqrt{N_0}} \lessp \frac{1}{\sqrt{N_0}}
\end{align*}
So we have
\begin{equation}
    \|\betaols - \beta^*\|_2 \lessp s^* + \frac{1}{\sqrt{n_\dagger}} + \frac{1}{\sqrt{N_0}}.
\label{appen:eq:olsrate}
\end{equation}
As we assume that $n_\dagger \ll N_0$, combining (\ref{eq:triagular}), (\ref{appen:eq:re0rate}) and (\ref{appen:eq:olsrate}) we have
\begin{align*}
     \| \ours(\widehat\smax) - \beta^*\|_2 \lessp  \ s^* + \frac{1}{\sqrt{n_\dagger}} + \text{Err}_{\mix} 
\end{align*}
\qed

\section{Experiment details and additional results}
\label{appen:sec:add}

\subsection{Simulation settings}
\label{appen:simulationset}
We now introduce the detailed choice of the distribution of $X$ and the regression coefficient $\alpha_l$ on each site. We set $L=5,N_l=2000,n_l=500,N_0=2000$ by default if not specified purposely. The dimension of $X$ is $p = 200$, and for low dimensional settings we set $q = \dim A = 5$. The source data are generated differently for each source site, with both covariate shift and conditional model drift. as follows. First, at each source site $l \in [L]$, we generate $A\ul_i (i \in [N_l])$ i.i.d. from a Gaussian distribution $N(\mu_l,\sigma^2_A I_{q})$ and set the first element 1. For each $W$, the first five elements are calculated by $W_1 = k(A_1-A_3),W_2=k(A_2-A_4),W_3=kA_3,W_4=W_5=kA_4$, and we keep $k=0.3$ creating a moderate correlation between $A$ and $W$. The rest elements of $W$ are 0, and we add a small noise $N(0,0.1^2)$ to each element of $W$. For each source site we generate the outcome $Y$ using a linear model
\[
    Y\ul_i = \alpha_l\trans A\ul_i + \gamma_l\trans W\ul_i + \varepsilon\ul_i,
\]
where $i \in [n_l]$ and $\varepsilon\ul_i$ is i.i.d Gaussian $N(0,0.5^2)$. It is noteworthy that on each source site, model $\PP\xl$ depends on $\mu_l$; model $\PP_{Y|X}\ul$ is largely determined by $\alpha_l$ and $\gamma_l$. To model both covariate shift and conditional model drift, we design that $\mu_l,\alpha_l$ and $\gamma_l$ are different across all the source sites. For the detailed choice of $\mu_l,\alpha_l$ and $\gamma_l$, in the most frequently used setting $L=5$ we set each mean of the covariates $A\ul$ as
\begin{align*}
    \mu_{A1}  & = (-2,0,1,0)\trans, \\
    \mu_{A2}  & = (0,-1,2,1)\trans,\\
    \mu_{A3}  & = (-1,2,0,1)\trans, \\
    \mu_{A4}  & = (1,1,-1,2)\trans, \\
    \mu_{A5}  & = (2,1,1,2)\trans, 
\end{align*}
and generate $A\ul_i \sim N(\mu_{Al},0.25I_q)$. To create correlation between $W\ul$ and $A\ul$, we set $W\ul_1 = 0.5(A\ul_1 - A\ul_3),W\ul_2 = 0.5(A\ul_2 - A\ul_4),W\ul_3 = 0.5A\ul_3,W\ul_4 = W\ul_5 = 0.5A\ul_4$ for each source site $l=1,2,\cdots,L$. Then we will add a Gaussian noise $N(0,0.1)$ to each element in $W\ul$. Finally $X\ul_i = (A\ul_i,W\ul_i)$ where the intercept term is incorporated into $A\ul_i$. The dimension of $A\ul$ is $1+q = 1+4=5$, and dimension of $W\ul$ is $195$.

On each source site, outcome $Y\ul$ is generated using
\[
    Y\ul_i = \alpha_l\trans A\ul_i + \gamma_l\trans W\ul_i + \varepsilon\ul_i = \beta_l\trans X_i\ul + \varepsilon\ul_i
\]
where $\beta_l = (\alpha_l,\gamma_l)$ and $X\ul_i = (A\ul_i,W\ul_i)$. Each $\alpha_l$ is $5-$dimensional and chosen as
\begin{align*}
    \alpha_1  & = (0,4,4,3,-3)\trans, \\
    \alpha_2  & = (-3,3,-1,3,-3)\trans, \\
    \alpha_3  & = (-3,-3,0,-3,-3)\trans, \\
    \alpha_4  & = (-6,6,6,6,-6)\trans, \\
    \alpha_5  & = (-3,-3,0,0,-1)\trans,
\end{align*}
where $\alpha_4$ is farther away from the origin then the other four coefficients. For 195-dimensional $\gamma_l,$ the first 6 elements is chosen as
\begin{align*}
    \gamma_1[1:6] & =  (0.5,-0.2,0,0,1,0)\trans \\
    \gamma_2[1:6] & =  (0,0.5,-0.2,0,0,1)\trans \\
    \gamma_3[1:6] & =  (0,0,0.2,-0.5,0,1)\trans \\
    \gamma_4[1:6] & =  (1,0,0,0.2,-0.5,0)\trans \\
    \gamma_5[1:6] & =  (0,0,0,1,0.2,-0.5)\trans
\end{align*}
and the rest of each $\gamma_l$ are Gaussian noise $N(0,0.1)$. The generation of target data is introduced in Section \ref{simu:benchmarks}.

In the setting where $L=10$, the source sites 6-10 are nearly duplicates of the first five source sites. We introduce a small perturbation as Gaussian noise, $N(0, 0.25)$, to each of $\mu_{Al}$, $\alpha_l$, and $\gamma_l$, as described, to differentiate the parameters for these new sites. 

To evaluate distribution robustness and generalizability, we uniformly sample 100 different $\delta^{*(b)}$ on the simplex $\Delta_L$ to generate the corresponding outcome $Y_i^{(0,b)}$, and report the average or worst-case performance (highest standardized MSE) among the 100 trials ($b=1,2,\cdots,100$). MSE is standardized by the average variance of $Y_i^{(0,b)}$.
By default, we generate a small $n_\dagger = 20$ labeled sample with $Y^\dagger_i$ to obtain $\widehat{\smax}$ using tuning method in Section \ref{sec:tuning}. We repeat 500 times of simulation for each setting to summarize the numerical performance.

In high-dimensional settings, as discussed in Section \ref{subsec:simu:highd}, we generate the data following the same approach, except that the entire $X^{(l)}$ vector is now used as the covariate of interest, $A^{(l)}$. For the data generation under the contamination model, we still generate target $Y$ using the linear model
$$
Y\uz_i = \beta_0\trans X\uz_i + \varepsilon\uz_i.
$$
Here $\beta_0 = (1-s^*)\suml \rho^*_l \beta_l + s^* \beta^{(\varepsilon)}$, and $\beta^{(\varepsilon)} = 0.4\suml \beta_l$, which means that the contaminated conditional distribution is approximately twice of the source average models. For the worst-case performance in the contamination model, we set $\beta^{(\varepsilon)} = U\suml \beta_l$ and generate $U$ from Uniform$(0,1)$ distribution, then calculate the highest loss over 100 randomly generated $\beta^{(\varepsilon)}$.


